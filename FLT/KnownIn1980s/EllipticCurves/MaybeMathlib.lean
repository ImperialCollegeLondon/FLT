/-! ## тЖТ `Mathlib.Algebra.Group.Basic` -/

/-- Upgrading a generically additive map to a globally additive one: if
`f (a * b) = f a + f b` holds off a bad set of pairs, and for every pair an auxiliary
`w` exists making the three pairs `(a * b, w)`, `(a, b * w)`, `(b, w)` good, then
additivity holds everywhere, by cancellation of `f w`. -/
theorem map_mul_of_generic {G H : Type*} [CommGroup G] [AddCommGroup H]
    (f : G тЖТ H) (Bad : Set (G ├Ч G))
    (hmul : тИА a b : G, (a, b) тИЙ Bad тЖТ f (a * b) = f a + f b)
    (hgen : тИА a b : G, тИГ w : G, (a * b, w) тИЙ Bad тИз (a, b * w) тИЙ Bad тИз (b, w) тИЙ Bad)
    (a b : G) : f (a * b) = f a + f b := by
  obtain тЯиw, h1, h2, h3тЯй := hgen a b
  have key : f (a * b) + f w = f a + f b + f w := by
    rw [тЖР hmul _ _ h1, mul_assoc a b w, hmul _ _ h2, hmul _ _ h3, тЖР add_assoc]
  exact add_right_cancel key

/-! ## тЖТ `Mathlib.Algebra.Group.Subgroup.ZPowers.Lemmas` -/

namespace MonoidHom

/-- Membership of the cyclic subgroup generated by `q` transfers along an injective
group homomorphism, in both directions. -/
@[to_additive]
theorem map_mem_zpowers_iff {G N F : Type*} [Group G] [Group N] [FunLike F G N]
    [MonoidHomClass F G N] {f : F} (hf : Function.Injective f) {q u : G} :
    f u тИИ Subgroup.zpowers (f q) тЖФ u тИИ Subgroup.zpowers q :=
  (f : G тЖТ* N).map_zpowers q тЦ╕ Subgroup.mem_map_iff_mem hf

end MonoidHom

/-! ## тЖТ `Mathlib.Algebra.Polynomial.Cardinal` (or `Mathlib.Algebra.Polynomial.Basic`) -/

namespace Polynomial

/-- The polynomial ring over a countable semiring is countable. -/
instance instCountable {R : Type*} [Semiring R] [Countable R] : Countable R[X] := by
  rw [тЖР Cardinal.mk_le_aleph0_iff]
  calc Cardinal.mk R[X] тЙд max (Cardinal.mk R) Cardinal.aleph0 := cardinalMk_le_max
    _ тЙд Cardinal.aleph0 := max_le Cardinal.mk_le_aleph0 le_rfl

end Polynomial

/-! ## тЖТ `Mathlib.FieldTheory.RatFunc.AsPolynomial`

`instCountable` here depends on `Polynomial.instCountable` from the section above. -/

namespace RatFunc

variable {K : Type*} [Field K]

/-- The rational-function variable `X` is not equal to `1`. -/
theorem X_ne_one : (RatFunc.X : RatFunc K) тЙа 1 := fun h тЖж by
  have h2 : (Polynomial.X : Polynomial K) = 1 := RatFunc.algebraMap_injective K
    (by rw [RatFunc.algebraMap_X, map_one]; exact h)
  simpa using congrArg Polynomial.natDegree h2

/-- In the field of rational functions, `1 - X` is nonzero. -/
theorem one_sub_X_ne_zero : (1 : RatFunc K) - RatFunc.X тЙа 0 := by
  have h1 : (1 : RatFunc K) - RatFunc.X
      = algebraMap (Polynomial K) (RatFunc K) (1 - Polynomial.X) := by
    rw [map_sub, map_one, RatFunc.algebraMap_X]
  rw [h1, Ne, тЖР map_zero (algebraMap (Polynomial K) (RatFunc K))]
  intro h
  have h2 : (1 : Polynomial K) - Polynomial.X = 0 :=
    IsFractionRing.injective (Polynomial K) (RatFunc K) h
  have h3 : (Polynomial.X : Polynomial K) = 1 := by linear_combination -h2
  simpa [Polynomial.coeff_X_one, Polynomial.coeff_one] using
    congrArg (fun p => Polynomial.coeff p 1) h3

/-- The field of rational functions over a countable field is countable. -/
instance instCountable [Countable K] : Countable (RatFunc K) :=
  Function.Surjective.countable
    (f := fun p : Polynomial K ├Ч (nonZeroDivisors (Polynomial K)) =>
      IsLocalization.mk' (RatFunc K) p.1 p.2)
    (fun r => by
      obtain тЯитЯиp, qтЯй, hтЯй := IsLocalization.mk'_surjective (nonZeroDivisors (Polynomial K)) r
      exact тЯи(p, q), hтЯй)

end RatFunc

/-! ## тЖТ `Mathlib.RingTheory.PowerSeries.Basic`

Evaluating power-series coefficients through a ring homomorphism `╬╡ : S тЖТ+* тДВ`: if the
sequences `╬╡ (coeff n ╧Ж) * qтБ┐` and `╬╡ (coeff n ╧И) * qтБ┐` have sums, then so do the sequences
for `╧Ж + ╧И`, `-╧Ж`, `╧Ж - ╧И` and `╧Ж * ╧И` (Cauchy product). The `mul` case uses that unconditional
summation over `тДВ` is absolute (`Summable.norm`), so the target is kept at `тДВ`; a more general
statement over an `RCLike` (or finite-dimensional real normed) field would carry the extra
`FiniteDimensional тДЭ _` typeclass. Needs the analysis imports above, so an upstream home might
instead be an analysis-side file such as `Mathlib.Analysis.Normed.Ring.InfiniteSum`. -/

section PowerSeriesEval

open scoped PowerSeries

variable {S : Type*} [CommRing S]

theorem hasSum_ringHom_add (╬╡ : S тЖТ+* тДВ) {q : тДВ} {╧Ж ╧И : SтЯжXтЯз} {P Q : тДВ}
    (h╧Ж : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧Ж) * q ^ n) P)
    (h╧И : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧И) * q ^ n) Q) :
    HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n (╧Ж + ╧И)) * q ^ n) (P + Q) := by
  refine (h╧Ж.add h╧И).congr_fun fun n тЖж ?_
  simp only [map_add, add_mul]

theorem hasSum_ringHom_neg (╬╡ : S тЖТ+* тДВ) {q : тДВ} {╧Ж : SтЯжXтЯз} {P : тДВ}
    (h╧Ж : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧Ж) * q ^ n) P) :
    HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n (-╧Ж)) * q ^ n) (-P) := by
  refine h╧Ж.neg.congr_fun fun n тЖж ?_
  simp only [map_neg, neg_mul]

theorem hasSum_ringHom_sub (╬╡ : S тЖТ+* тДВ) {q : тДВ} {╧Ж ╧И : SтЯжXтЯз} {P Q : тДВ}
    (h╧Ж : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧Ж) * q ^ n) P)
    (h╧И : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧И) * q ^ n) Q) :
    HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n (╧Ж - ╧И)) * q ^ n) (P - Q) := by
  simpa [sub_eq_add_neg] using hasSum_ringHom_add ╬╡ h╧Ж (hasSum_ringHom_neg ╬╡ h╧И)

theorem hasSum_ringHom_mul (╬╡ : S тЖТ+* тДВ) {q : тДВ} {╧Ж ╧И : SтЯжXтЯз} {P Q : тДВ}
    (h╧Ж : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧Ж) * q ^ n) P)
    (h╧И : HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n ╧И) * q ^ n) Q) :
    HasSum (fun n тЖж ╬╡ (PowerSeries.coeff n (╧Ж * ╧И)) * q ^ n) (P * Q) := by
  have hprod := hasSum_sum_range_mul_of_summable_norm h╧Ж.summable.norm h╧И.summable.norm
  rw [h╧Ж.tsum_eq, h╧И.tsum_eq] at hprod
  refine hprod.congr_fun fun n тЖж ?_
  rw [PowerSeries.coeff_mul, тЖР Finset.Nat.sum_antidiagonal_eq_sum_range_succ
    (fun k l тЖж (╬╡ (PowerSeries.coeff k ╧Ж) * q ^ k) * (╬╡ (PowerSeries.coeff l ╧И) * q ^ l)),
    map_sum, Finset.sum_mul]
  refine Finset.sum_congr rfl fun p hp тЖж ?_
  rw [map_mul, тЖР Finset.mem_antidiagonal.mp hp, pow_add]
  ring

end PowerSeriesEval

/-! ## тЖТ `Mathlib.NumberTheory.Bernoulli` -/

theorem bernoulli'_five : bernoulli' 5 = 0 := by
  rw [bernoulli'_def]; norm_num [Finset.sum_range_succ, Finset.sum_range_zero, Nat.choose]

theorem bernoulli'_six : bernoulli' 6 = 1 / 42 := by
  rw [bernoulli'_def]
  norm_num [Finset.sum_range_succ, Finset.sum_range_zero, Nat.choose, bernoulli'_five]

/-! ## тЖТ `Mathlib.NumberTheory.LSeries.HurwitzZetaValues`

Depends on `bernoulli'_six` from the section above. -/

section RiemannZeta

open Complex

open Real in
/-- The value `╬╢(6) = ╧АтБ╢/945` (companion to Mathlib's `riemannZeta_four`). -/
theorem riemannZeta_six : riemannZeta 6 = (╧А : тДВ) ^ 6 / 945 := by
  have h := riemannZeta_two_mul_nat (k := 3) (by norm_num)
  rw [show (2 * ((3 : тДХ) : тДВ)) = 6 by norm_num] at h
  rw [h, bernoulli_eq_bernoulli'_of_ne_one (by norm_num), bernoulli'_six]
  norm_num [Nat.factorial]
  ring

end RiemannZeta

/-! ## тЖТ `Mathlib.AlgebraicGeometry.EllipticCurve.VariableChange`

The admissible change of variables `тЯиu, r, s, tтЯй = тЯи-1, 0, -aтВБ, -aтВГтЯй` fixes every Weierstrass
curve `W` (it induces negation on the points of `W`, see
`FLT.Mathlib.AlgebraicGeometry.EllipticCurve.Affine.VariableChange`). The main result of this
section is the converse classification `WeierstrassCurve.smul_eq_self_iff`: if `W.cтВД тЙа 0` and
`W.cтВЖ тЙа 0` тАФ equivalently, if `j(W) тИЙ {0, 1728}` when `W` is elliptic тАФ then the *only*
admissible changes of variables fixing `W` are the identity and the negation. This is the
Weierstrass-equation incarnation of `Aut(E) = {┬▒1}` for `j(E) тЙа 0, 1728` (Silverman, *The
Arithmetic of Elliptic Curves*, Theorem III.10.1), valid in every characteristic. -/

namespace WeierstrassCurve

variable {R : Type*} [CommRing R]

/-- The admissible change of variables `тЯиu, r, s, tтЯй = тЯи-1, 0, -aтВБ, -aтВГтЯй` attached to a
Weierstrass curve `W`. It fixes `W` (`negVariableChange_smul`) and induces negation on
the points of `W` (`negVariableChange_mapX`, `negVariableChange_mapY`). -/
def negVariableChange (W : WeierstrassCurve R) : VariableChange R :=
  тЯи-1, 0, -W.aтВБ, -W.aтВГтЯй

/-- The negation change of variables fixes every Weierstrass curve. -/
theorem negVariableChange_smul (W : WeierstrassCurve R) : W.negVariableChange тАв W = W := by
  ext <;>
    simp only [negVariableChange, variableChange_aтВБ, variableChange_aтВВ, variableChange_aтВГ,
      variableChange_aтВД, variableChange_aтВЖ, inv_neg, inv_one, Units.val_neg, Units.val_one] <;>
    ring

/-- The negation change of variables is an involution of the group of changes of
variables. -/
theorem negVariableChange_mul_self (W : WeierstrassCurve R) :
    W.negVariableChange * W.negVariableChange = 1 := by
  ext <;> simp only [negVariableChange, VariableChange.mul_def, mul_neg, mul_one, neg_neg,
    Units.val_neg, Units.val_one, even_two, Even.neg_pow, one_pow, add_zero, neg_mul, one_mul,
    add_neg_cancel, zero_mul, neg_zero, VariableChange.one_def]
  ring

theorem inv_negVariableChange (W : WeierstrassCurve R) :
    W.negVariableChangeтБ╗┬╣ = W.negVariableChange :=
  inv_eq_of_mul_eq_one_right (negVariableChange_mul_self W)

theorem map_negVariableChange {A : Type*} [CommRing A] (W : WeierstrassCurve R) (╧Ж : R тЖТ+* A) :
    W.negVariableChange.map ╧Ж = (W.map ╧Ж).negVariableChange := by
  ext <;> simp [negVariableChange, VariableChange.map]

variable {F : Type*} [Field F]

-- In characteristic `2` a Weierstrass curve with `cтВД тЙа 0` has `aтВБ тЙа 0`: there `cтВД = bтВВ┬▓ = aтВБтБ┤`.
private theorem aтВБ_ne_zero_of_cтВД_ne_zero {W : WeierstrassCurve F} (hcтВД : W.cтВД тЙа 0)
    (h2 : (2 : F) = 0) : W.aтВБ тЙа 0 := by
  intro haтВБ
  apply hcтВД
  simp only [cтВД, bтВВ, bтВД, haтВБ]
  linear_combination (8 * W.aтВВ ^ 2 - 24 * W.aтВД) * h2

-- The scaling unit of an admissible change of variables fixing a Weierstrass equation with
-- `cтВД тЙа 0` and `cтВЖ тЙа 0` squares to `1`.
private theorem u_sq_eq_one {W : WeierstrassCurve F} (hcтВД : W.cтВД тЙа 0) (hcтВЖ : W.cтВЖ тЙа 0)
    {C : VariableChange F} (h : C тАв W = W) : (C.u : F) ^ 2 = 1 := by
  have h4 : (C.u : F)тБ╗┬╣ ^ 4 * W.cтВД = W.cтВД := by
    rw [тЖР Units.val_inv_eq_inv_val, тЖР variableChange_cтВД, h]
  have h6 : (C.u : F)тБ╗┬╣ ^ 6 * W.cтВЖ = W.cтВЖ := by
    rw [тЖР Units.val_inv_eq_inv_val, тЖР variableChange_cтВЖ, h]
  have h4' : (C.u : F) ^ 4 = 1 := by
    have h := mul_right_cancelтВА hcтВД (h4.trans (one_mul W.cтВД).symm)
    rwa [inv_pow, inv_eq_one] at h
  have h6' : (C.u : F) ^ 6 = 1 := by
    have h := mul_right_cancelтВА hcтВЖ (h6.trans (one_mul W.cтВЖ).symm)
    rwa [inv_pow, inv_eq_one] at h
  linear_combination h6' - (C.u : F) ^ 2 * h4'

-- `r = 0` for an admissible change of variables fixing a Weierstrass equation with `cтВД тЙа 0`,
-- given that its scaling unit squares to `1`.
private theorem r_eq_zero {W : WeierstrassCurve F} (hcтВД : W.cтВД тЙа 0) {C : VariableChange F}
    (h : C тАв W = W) (hu2 : (C.u : F) ^ 2 = 1) : C.r = 0 := by
  have hb2 : (C.u : F)тБ╗┬╣ ^ 2 * (W.bтВВ + 12 * C.r) = W.bтВВ := by
    rw [тЖР Units.val_inv_eq_inv_val, тЖР variableChange_bтВВ, h]
  have hb4 : (C.u : F)тБ╗┬╣ ^ 4 * (W.bтВД + C.r * W.bтВВ + 6 * C.r ^ 2) = W.bтВД := by
    rw [тЖР Units.val_inv_eq_inv_val, тЖР variableChange_bтВД, h]
  have hinv2 : (C.u : F)тБ╗┬╣ ^ 2 = 1 := by rw [inv_pow, hu2, inv_one]
  have hinv4 : (C.u : F)тБ╗┬╣ ^ 4 = 1 := by
    rw [inv_pow, show (C.u : F) ^ 4 = ((C.u : F) ^ 2) ^ 2 by ring, hu2, one_pow, inv_one]
  rw [hinv2, one_mul] at hb2
  rw [hinv4, one_mul] at hb4
  have h12 : (12 : F) * C.r = 0 := by linear_combination hb2
  have hrb : C.r * W.bтВВ + 6 * C.r ^ 2 = 0 := by linear_combination hb4
  rcases mul_eq_zero.mp h12 with h12z | hr
  ┬╖ -- the characteristic divides 12, hence 6 and 24 vanish and `cтВД = bтВВ┬▓`
    have h6 : (6 : F) = 0 := by
      have h26 : (2 : F) * 6 = 0 := by linear_combination h12z
      rcases mul_eq_zero.mp h26 with h2z | h6z
      ┬╖ linear_combination 3 * h2z
      ┬╖ exact h6z
    have h24 : (24 : F) = 0 := by linear_combination 2 * h12z
    have hb2ne : W.bтВВ тЙа 0 := by
      intro hb
      apply hcтВД
      simp only [cтВД, hb]
      linear_combination -W.bтВД * h24
    have hr' : C.r * W.bтВВ = 0 := by linear_combination hrb - C.r ^ 2 * h6
    exact (mul_eq_zero.mp hr').resolve_right hb2ne
  ┬╖ exact hr

-- The `aтВД`-transformation law of a change of variables fixing `W`, normalised via `u┬▓ = 1`
-- and `r = 0`.
private theorem aтВД_relation {W : WeierstrassCurve F} {C : VariableChange F} (h : C тАв W = W)
    (hu2 : (C.u : F) ^ 2 = 1) (hr : C.r = 0) : C.s * W.aтВГ + C.t * W.aтВБ + 2 * C.s * C.t = 0 := by
  have huu : (C.u : F)тБ╗┬╣ = (C.u : F) :=
    inv_eq_of_mul_eq_one_right (by linear_combination hu2)
  have e4 := congrArg aтВД h
  rw [variableChange_aтВД, Units.val_inv_eq_inv_val, huu,
    show (C.u : F) ^ 4 = ((C.u : F) ^ 2) ^ 2 by ring, hu2, one_pow, one_mul] at e4
  linear_combination -e4 + (2 * W.aтВВ - C.s * W.aтВБ + 3 * C.r) * hr

-- `t = 0` for a change of variables fixing `W` with `u┬▓ = 1`, `r = s = 0` and `2t = 0`.
private theorem t_eq_zero {W : WeierstrassCurve F} (hcтВД : W.cтВД тЙа 0) {C : VariableChange F}
    (h : C тАв W = W) (hu2 : (C.u : F) ^ 2 = 1) (hr : C.r = 0) (hs : C.s = 0)
    (h2t : (2 : F) * C.t = 0) : C.t = 0 := by
  have hta : C.t * W.aтВБ = 0 := by
    linear_combination aтВД_relation h hu2 hr - (W.aтВГ + 2 * C.t) * hs
  rcases mul_eq_zero.mp h2t with h2z | ht0
  ┬╖ exact (mul_eq_zero.mp hta).resolve_right (aтВБ_ne_zero_of_cтВД_ne_zero hcтВД h2z)
  ┬╖ exact ht0

-- A change of variables with `u = 1` and `r = s = t = 0` is the identity.
private theorem eq_one_of {C : VariableChange F} (hu : (C.u : F) = 1) (hr : C.r = 0) (hs : C.s = 0)
    (ht : C.t = 0) : C = 1 :=
  VariableChange.ext (Units.ext hu) hr hs ht

-- A change of variables with `u = -1`, `r = 0`, `s = -aтВБ` and `t = -aтВГ` is the negation.
private theorem eq_negVariableChange_of {W : WeierstrassCurve F} {C : VariableChange F}
    (hu : (C.u : F) = -1) (hr : C.r = 0) (hs : W.aтВБ + C.s = 0) (ht : C.t + W.aтВГ = 0) :
    C = W.negVariableChange :=
  VariableChange.ext (Units.ext hu) hr (show C.s = -W.aтВБ by linear_combination hs)
    (show C.t = -W.aтВГ by linear_combination ht)

-- In characteristic `2` a change of variables fixing `W` with `u┬▓ = 1`, `r = 0` and
-- `s = aтВБ` is the negation (note `-1 = 1` there).
private theorem eq_negVariableChange_of_char_two {W : WeierstrassCurve F} (hcтВД : W.cтВД тЙа 0)
    {C : VariableChange F} (h : C тАв W = W) (hu2 : (C.u : F) ^ 2 = 1) (hr : C.r = 0)
    (hs : W.aтВБ + C.s = 0) (h2 : (2 : F) = 0) : C = W.negVariableChange := by
  have hta : W.aтВБ * (C.t - W.aтВГ) = 0 := by
    linear_combination aтВД_relation h hu2 hr - W.aтВГ * hs - C.s * C.t * h2
  have ht := (mul_eq_zero.mp hta).resolve_left (aтВБ_ne_zero_of_cтВД_ne_zero hcтВД h2)
  have hu : (C.u : F) = -1 :=
    (sq_eq_one_iff.mp hu2).elim (fun hu1 => by linear_combination hu1 + h2) id
  exact eq_negVariableChange_of hu hr hs (by linear_combination ht + W.aтВГ * h2)

/-- The classification of automorphisms of a Weierstrass equation with `cтВД тЙа 0` and
`cтВЖ тЙа 0` (equivalently, of an elliptic curve with `j тЙа 0, 1728`, in every
characteristic): the only admissible changes of variables fixing the equation are the
identity and the negation `тЯи-1, 0, -aтВБ, -aтВГтЯй`. This is Silverman, *The Arithmetic of
Elliptic Curves*, Theorem III.10.1, in Weierstrass-equation form. -/
theorem smul_eq_self_iff {W : WeierstrassCurve F} (hcтВД : W.cтВД тЙа 0) (hcтВЖ : W.cтВЖ тЙа 0)
    {C : VariableChange F} : C тАв W = W тЖФ C = 1 тИи C = W.negVariableChange := by
  constructor
  ┬╖ intro h
    have hu2 := u_sq_eq_one hcтВД hcтВЖ h
    have hr := r_eq_zero hcтВД h hu2
    have huu : (C.u : F)тБ╗┬╣ = (C.u : F) :=
      inv_eq_of_mul_eq_one_right (by linear_combination hu2)
    -- the `aтВБ`, `aтВВ`, `aтВГ` transformation laws, with the inverse powers collapsed via `u┬▓ = 1`
    have e1 := congrArg aтВБ h
    have e2 := congrArg aтВВ h
    have e3 := congrArg aтВГ h
    rw [variableChange_aтВБ, Units.val_inv_eq_inv_val, huu] at e1
    rw [variableChange_aтВВ, Units.val_inv_eq_inv_val, huu, hu2, one_mul] at e2
    rw [variableChange_aтВГ, Units.val_inv_eq_inv_val, huu, pow_succ, hu2, one_mul] at e3
    have hs2 : C.s * (W.aтВБ + C.s) = 0 := by linear_combination -e2 + 3 * hr
    rcases sq_eq_one_iff.mp hu2 with hu1 | hun1
    ┬╖ -- `u = 1`
      have h2s : (2 : F) * C.s = 0 := by linear_combination e1 - (W.aтВБ + 2 * C.s) * hu1
      have h2t : (2 : F) * C.t = 0 := by
        linear_combination e3 - (W.aтВГ + C.r * W.aтВБ + 2 * C.t) * hu1 - W.aтВБ * hr
      rcases mul_eq_zero.mp hs2 with hs0 | hsa
      ┬╖ -- `s = 0`, hence `t = 0` and `C = 1`
        exact Or.inl (eq_one_of hu1 hr hs0 (t_eq_zero hcтВД h hu2 hr hs0 h2t))
      ┬╖ -- `s = -aтВБ`: characteristic `2` (or `aтВБ = 0`)
        have h2aтВБ : (2 : F) * W.aтВБ = 0 := by linear_combination 2 * hsa - h2s
        rcases mul_eq_zero.mp h2aтВБ with h2z | haтВБ0
        ┬╖ exact Or.inr (eq_negVariableChange_of_char_two hcтВД h hu2 hr hsa h2z)
        ┬╖ -- `aтВБ = 0`, hence `s = 0`, `t = 0` and `C = 1`
          have hs0 : C.s = 0 := by linear_combination hsa - haтВБ0
          exact Or.inl (eq_one_of hu1 hr hs0 (t_eq_zero hcтВД h hu2 hr hs0 h2t))
    ┬╖ -- `u = -1`
      have h2sa : (2 : F) * (C.s + W.aтВБ) = 0 := by
        linear_combination -e1 + (W.aтВБ + 2 * C.s) * hun1
      rcases mul_eq_zero.mp h2sa with h2z | hsa
      ┬╖ -- characteristic `2`
        rcases mul_eq_zero.mp hs2 with hs0 | hsa
        ┬╖ -- `s = 0`, hence `t = 0` and `C = 1` (with `-1 = 1`)
          exact Or.inl (eq_one_of (by linear_combination hun1 - h2z) hr hs0
            (t_eq_zero hcтВД h hu2 hr hs0 (by linear_combination C.t * h2z)))
        ┬╖ -- `s = -aтВБ`: `C` is the negation
          exact Or.inr (eq_negVariableChange_of_char_two hcтВД h hu2 hr hsa h2z)
      ┬╖ -- `s = -aтВБ`
        have h2ta : (2 : F) * (C.t + W.aтВГ) = 0 := by
          linear_combination -e3 + (W.aтВГ + C.r * W.aтВБ + 2 * C.t) * hun1 - W.aтВБ * hr
        rcases mul_eq_zero.mp h2ta with h2z | hta
        ┬╖ -- characteristic `2`: `t = aтВГ = -aтВГ`
          exact Or.inr (eq_negVariableChange_of_char_two hcтВД h hu2 hr
            (by linear_combination hsa) h2z)
        ┬╖ -- `t = -aтВГ`: `C` is the negation
          exact Or.inr (eq_negVariableChange_of hun1 hr (by linear_combination hsa) hta)
  ┬╖ rintro (rfl | rfl)
    ┬╖ exact one_smul _ _
    ┬╖ exact W.negVariableChange_smul

end WeierstrassCurve

/-! ## тЖТ `Mathlib.AlgebraicGeometry.EllipticCurve.Affine.Point`

`WeierstrassCurve.Affine.Point.congr` transports the group of affine points along an equality
`W = W'` of Weierstrass curves, as an isomorphism of groups fixing the coordinates of every
affine point. It exists so that constructions transported along propositional equalities of
curves (such as Tate's `tateEquiv`, which is transported along `tateVariableChange_smul`) can
be characterised without `Eq.mpr` terms. -/

namespace WeierstrassCurve.Affine.Point

variable {F : Type*} [Field F] [DecidableEq F] {W W' : WeierstrassCurve F}

/-- Transport of affine points along an equality of Weierstrass curves: the additive
equivalence fixing the coordinates of every affine point. -/
def congr (h : W = W') : W.toAffine.Point тЙГ+ W'.toAffine.Point :=
  h тЦ╕ AddEquiv.refl W.toAffine.Point

@[simp]
theorem congr_zero (h : W = W') : Point.congr h (0 : W.toAffine.Point) = 0 := by
  subst h
  rfl

@[simp]
theorem congr_some (h : W = W') {x y : F} (hxy : W.toAffine.Nonsingular x y)
    (hxy' : W'.toAffine.Nonsingular x y) :
    Point.congr h (.some x y hxy) = .some x y hxy' := by
  subst h
  rfl

end WeierstrassCurve.Affine.Point

/-! ## тЖТ `Mathlib.Analysis.SpecialFunctions.Elliptic.Weierstrass` -/

/-!

# The addition theorem for the Weierstrass `тДШ`-function

Material destined for Mathlib. Let `L` be a pair of periods, `╬Ы` its lattice, and `тДШ`,
`тДШ'` the associated Weierstrass functions (`Mathlib.Analysis.SpecialFunctions.Elliptic.
Weierstrass`). This file proves:

* `PeriodPair.deriv_derivWeierstrassP` : `тДШ''(z) = 6тДШ(z)┬▓ - gтВВ/2` away from `╬Ы`, together
  with the third and fourth derivatives `iteratedDeriv_three_weierstrassP`,
  `iteratedDeriv_four_weierstrassP` obtained by differentiating it;
* `PeriodPair.weierstrassP_add_sq` тАФ **the addition theorem** in polynomial form: for
  `zтВБ, zтВВ, zтВБ + zтВВ тИЙ ╬Ы`,

  `(тДШ(zтВБ+zтВВ) + тДШ(zтВБ) + тДШ(zтВВ))┬╖(тДШ(zтВБ) - тДШ(zтВВ))┬▓ = (тДШ'(zтВБ) - тДШ'(zтВВ))┬▓/4`;

* `PeriodPair.derivWeierstrassP_add_sq` тАФ its `zтВБ`-derivative, expressing
  `тДШ'(zтВБ+zтВВ)┬╖(тДШ(zтВБ) - тДШ(zтВВ))┬▓` polynomially in `тДШ(zтВБ┬▒...), тДШ', gтВВ`.

The polynomial form requires no `тДШ(zтВБ) тЙа тДШ(zтВВ)` hypothesis; dividing by
`(тДШ(zтВБ) - тДШ(zтВВ))┬▓` when it is nonzero recovers the classical formula
`тДШ(zтВБ+zтВВ) = ┬╝((тДШ'zтВБ-тДШ'zтВВ)/(тДШzтВБ-тДШzтВВ))┬▓ - тДШzтВБ - тДШzтВВ`.

## Proof strategy

Both main results follow the strategy of mathlib's `PeriodPair.derivWeierstrassP_sq`
(the differential equation): the defect of the identity, extended by `0` on its polar
locus, is meromorphic and doubly periodic; multiplying by a suitable power of a local
uniformiser exhibits it as analytic with high-order vanishing at each pole candidate
(a finite computation with `iteratedDeriv` and the lattice sums
`PeriodPair.sumInvPow`/`PeriodPair.G`); hence the defect is entire, bounded (periodicity
plus compactness of a fundamental domain), constant by Liouville, and `0` by evaluation.

For the addition theorem with `zтВВ тИЙ ╬Ы` fixed, the polar locus in `zтВБ` is
`╬Ы тИк (╬Ы - zтВВ)`:

* at `╬Ы` (reduce to `0` by periodicity), the defect times `zтВБтБ╢` is analytic, and its
  first seven Taylor coefficients vanish тАФ a computation using the expansions
  `тДШ = тДШ[L-0] + zтБ╗┬▓`, `тДШ' = тДШ'[L-0] - 2zтБ╗┬│`, the values
  `iteratedDeriv_weierstrassPExcept_self` (Eisenstein numbers `G`), the derivatives of
  `zтВБ тЖж тДШ(zтВБ+zтВВ)` at `0` up to order 4 (this is where `deriv_derivWeierstrassP` enters),
  the vanishing of odd `G`'s, and finally the differential equation at `zтВВ`;
* at `╬Ы - zтВВ` (reduce to `-zтВВ` by periodicity), the defect times `(zтВБ+zтВВ)┬▓` is analytic
  and vanishes to order 3 тАФ a computation using only the evenness of `тДШ` and oddness
  of `тДШ'` at `-zтВВ`. In particular no two-torsion hypothesis on `zтВВ` is needed.
-/

open Filter
open scoped Topology Nat

noncomputable section

/-- **Liouville's theorem for lattice-periodic functions**: a `тДВ`-differentiable function
`f : E тЖТ F` on a finite-dimensional complex normed space `E`, invariant under translation by a
`тДд`-lattice `╬Ы`, takes the same value at any two points; in particular it is constant. Specialised
to `E = F = тДВ` and a rank-2 lattice this is Liouville's first theorem for elliptic functions. -/
theorem Differentiable.eq_of_zLattice_periodic
    {E : Type*} [NormedAddCommGroup E] [NormedSpace тДЭ E] [NormedSpace тДВ E] [FiniteDimensional тДЭ E]
    {F : Type*} [NormedAddCommGroup F] [NormedSpace тДВ F]
    {f : E тЖТ F} (hf : Differentiable тДВ f) (╬Ы : Submodule тДд E)
    [DiscreteTopology ╬Ы] [IsZLattice тДЭ ╬Ы]
    (hper : тИА w тИИ ╬Ы, тИА z, f (z + w) = f z) (x y : E) : f x = f y :=
  hf.apply_eq_apply_of_bounded (IsZLattice.isCompact_range_of_periodic ╬Ы _ hf.continuous
      (fun z w hw тЖж hper w hw z)).isBounded x y

namespace PeriodPair

variable (L : PeriodPair)

/-! ### Shared infrastructure for the Liouville arguments

Both main results are proved by the same template: a defect, extended by `0` on its polar locus,
is meromorphic and lattice-periodic; multiplying by a uniformiser of the right order clears the
pole once enough Taylor coefficients vanish (`analyticAt_of_mul_uniformiser`), so the defect is
entire; being entire and doubly periodic it is constant (`Differentiable.eq_of_zLattice_periodic`),
and vanishing at one point makes it `0`. -/

/-- (Implementation) `f` is analytic at `x` once a uniformiser `u` of order `k` clears the pole:
if `f ┬╖ u` is analytic at `x` and its first `k + 1` Taylor coefficients there vanish, then the
order of `f` at `x` is positive, so (given `f x = 0`) `f` is analytic at `x`. -/
private lemma analyticAt_of_mul_uniformiser {f u : тДВ тЖТ тДВ} {x : тДВ} {k : тДХ}
    (hf : MeromorphicAt f x) (hu : MeromorphicAt u x) (hzero : f x = 0)
    (horder : meromorphicOrderAt u x = k) (hfu : AnalyticAt тДВ (f * u) x)
    (hvanish : тИА i < k + 1, iteratedDeriv i (f * u) x = 0) : AnalyticAt тДВ f x := by
  refine .of_meromorphicOrderAt_pos (one_pos.trans_le ?_) hzero
  suffices ((k : тДд) + 1 : WithTop тДд) тЙд meromorphicOrderAt (f * u) x by
    rw [meromorphicOrderAt_mul hf hu, horder] at this
    rw [тЖР WithTop.add_le_add_iff_right (z := (k : WithTop тДд)) (by simp)]
    simpa [-add_le_add_iff_left_of_ne_top, add_comm] using! this
  rw [AnalyticAt.meromorphicOrderAt_eq hfu]
  exact ENat.monotone_map_iff.mpr Nat.mono_cast
    ((natCast_le_analyticOrderAt_iff_iteratedDeriv_eq_zero hfu).mpr fun i hi тЖж hvanish i hi)

/-! ### The second derivative: `тДШ'' = 6тДШ┬▓ - gтВВ/2`

The defect `deriv тДШ' - 6тДШ┬▓ + gтВВ/2` has, at each lattice point, a pole of order at most
`2` (the `zтБ╗тБ┤`-terms of `deriv тДШ'` and `6тДШ┬▓` cancel); multiplied by `z┬▓` it is analytic
with a triple zero at `0` тАФ the constant term is `-12тДШ[L-0](0) = 0`, the linear term is
`-12┬╖тДШ[L-0]'(0) = -24┬╖GтВГ = 0`, and the quadratic term is `gтВВ - 60┬╖GтВД = 0` by definition
of `gтВВ`. So the defect is entire, doubly periodic, hence zero.
-/

section SecondDerivative

/-- (Implementation) The defect of the second-derivative identity `тДШ'' = 6тДШ┬▓ - gтВВ/2`,
extended by `0` on the lattice. We show it is constantly zero:
see `PeriodPair.deriv_derivWeierstrassP`. -/
private def relationтВВ (z : тДВ) : тДВ :=
  letI := Classical.propDecidable
  if z тИИ L.lattice then 0 else deriv тДШ'[L] z - 6 * тДШ[L] z ^ 2 + L.gтВВ / 2

/-- (Implementation) Away from `0`, `deriv тДШ'[L] z = deriv тДШ'[L-0] z + 6/zтБ┤`. -/
private lemma deriv_derivWeierstrassP_eq {z : тДВ} (hz : z тИЙ L.lattice) :
    deriv тДШ'[L] z = deriv тДШ'[L - (0 : тДВ)] z + 6 / z ^ 4 := by
  have hz0 : z тЙа 0 := by rintro rfl; exact hz (zero_mem _)
  have hfun : тДШ'[L] = fun w тЖж тДШ'[L - (0 : тДВ)] w - 2 / w ^ 3 := by
    funext w
    have := L.derivWeierstrassPExcept_sub (0 : L.lattice) w
    simpa using this.symm
  have hEx : HasDerivAt тДШ'[L - (0 : тДВ)] (deriv тДШ'[L - (0 : тДВ)] z) z :=
    (L.analyticOnNhd_derivWeierstrassPExcept 0 z (fun h тЖж hz h.1)).differentiableAt.hasDerivAt
  have hpow : HasDerivAt (fun w : тДВ тЖж w ^ 3) (3 * z ^ 2) z := by simpa using hasDerivAt_pow 3 z
  have hdiv : HasDerivAt (fun w : тДВ тЖж 2 / w ^ 3)
      ((0 * z ^ 3 - 2 * (3 * z ^ 2)) / (z ^ 3) ^ 2) z :=
    (hasDerivAt_const z (2 : тДВ)).div hpow (pow_ne_zero 3 hz0)
  have hderiv : HasDerivAt тДШ'[L]
      (deriv тДШ'[L - (0 : тДВ)] z - (0 * z ^ 3 - 2 * (3 * z ^ 2)) / (z ^ 3) ^ 2) z := by
    rw [hfun]; exact hEx.sub hdiv
  rw [hderiv.deriv]
  field_simp
  ring

/-- (Implementation) `deriv тДШ'[L]` is lattice-periodic. -/
private lemma deriv_derivWeierstrassP_add_coe (x : тДВ) (l : L.lattice) :
    deriv тДШ'[L] (x + l) = deriv тДШ'[L] x := by
  rw [тЖР deriv_comp_add_const тДШ'[L] (l : тДВ) x]
  refine Filter.EventuallyEq.deriv_eq ?_
  filter_upwards with w using L.derivWeierstrassP_add_coe w l

@[local fun_prop]
private lemma meromorphic_deriv_derivWeierstrassP : Meromorphic (deriv тДШ'[L]) :=
  fun x тЖж (L.meromorphic_derivWeierstrassP x).deriv

@[local fun_prop]
private lemma meromorphic_relationтВВ : Meromorphic L.relationтВВ := by
  have : Meromorphic fun z тЖж deriv тДШ'[L] z - 6 * тДШ[L] z ^ 2 + L.gтВВ / 2 := by fun_prop
  refine fun x тЖж (this _).congr ?_
  filter_upwards [self_mem_nhdsWithin, mem_nhdsWithin_of_mem_nhds
    (L.compl_lattice_sdiff_singleton_mem_nhds _)] with w hw hw'
  rw [relationтВВ, if_neg (by simp_all)]

private lemma relationтВВ_mul_id_pow_two_eventuallyEq :
    (L.relationтВВ * id ^ 2) =с╢а[nhds 0] fun z тЖж
      deriv тДШ'[L - (0 : тДВ)] z * z ^ 2
        - 6 * (тДШ[L - (0 : тДВ)] z * тДШ[L - (0 : тДВ)] z) * z ^ 2
        - 12 * тДШ[L - (0 : тДВ)] z + L.gтВВ / 2 * z ^ 2 := by
  filter_upwards [L.compl_lattice_sdiff_singleton_mem_nhds _] with z hz
  by_cases hz0 : z = 0
  ┬╖ subst hz0; simp [relationтВВ]
  have hzL : z тИЙ L.lattice := fun h тЖж hz тЯиh, hz0тЯй
  have hP : тДШ[L] z = тДШ[L - (0 : тДВ)] z + 1 / z ^ 2 := by
    have := L.weierstrassPExcept_add (0 : L.lattice) z
    simpa using this.symm
  simp only [Pi.mul_apply, Pi.pow_apply, id_eq, relationтВВ, if_neg hzL]
  rw [L.deriv_derivWeierstrassP_eq hzL, hP]
  field_simp
  ring

@[local fun_prop]
private lemma analyticAt_relationтВВ_mul_id_pow_two :
    AnalyticAt тДВ (L.relationтВВ * id ^ 2) 0 := by
  refine .congr ?_ L.relationтВВ_mul_id_pow_two_eventuallyEq.symm
  fun_prop

attribute [local fun_prop] AnalyticAt.contDiffAt in
private lemma analyticAt_relationтВВ_zero : AnalyticAt тДВ L.relationтВВ 0 := by
  have horder : meromorphicOrderAt ((id : тДВ тЖТ тДВ) ^ 2) 0 = 2 := by
    have he : ((id : тДВ тЖТ тДВ) ^ 2) = ((┬╖ - (0 : тДВ)) ^ 2 : тДВ тЖТ тДВ) := by ext z; simp
    rw [he]; simpa using meromorphicOrderAt_pow_id_sub_const (x := (0 : тДВ)) (n := 2)
  refine analyticAt_of_mul_uniformiser (by fun_prop) (by fun_prop) (by simp [relationтВВ])
    horder (by fun_prop) fun i hiтВБ тЖж ?_
  rw [L.relationтВВ_mul_id_pow_two_eventuallyEq.iteratedDeriv_eq]
  simp (discharger := fun_prop) only [iteratedDeriv_fun_add, iteratedDeriv_fun_sub,
    iteratedDeriv_fun_mul, iteratedDeriv_const, iteratedDeriv_fun_pow_zero,
    iteratedDeriv_weierstrassPExcept_self]
  interval_cases i <;>
    simp [Finset.sum_range_succ, deriv_derivWeierstrassPExcept_self, weierstrassPExcept_zero,
      L.G_eq_zero_of_odd 3 (by decide), gтВВ, sumInvPow_zero, show (3 : тДХ)! = 6 from rfl]
  ring

@[local simp]
private lemma relationтВВ_add_coe (x : тДВ) (l : L.lattice) :
    L.relationтВВ (x + l) = L.relationтВВ x := by
  simp only [relationтВВ, weierstrassP_add_coe, L.deriv_derivWeierstrassP_add_coe]
  congr 1
  simpa using (L.lattice.toAddSubgroup.add_mem_cancel_right (y := x) l.2)

@[local simp]
private lemma relationтВВ_sub_coe (x : тДВ) (l : L.lattice) :
    L.relationтВВ (x - l) = L.relationтВВ x := by
  rw [тЖР L.relationтВВ_add_coe _ l, sub_add_cancel]

private lemma analyticAt_relationтВВ (x : тДВ) : AnalyticAt тДВ L.relationтВВ x := by
  by_cases hx : x тИИ L.lattice
  ┬╖ lift x to L.lattice using hx
    have := L.analyticAt_relationтВВ_zero
    rw [тЖР sub_self x.1] at this
    convert! this.comp (f := (┬╖ - x.1)) (by fun_prop)
    ext a
    simp
  ┬╖ have : AnalyticAt тДВ (fun z тЖж deriv тДШ'[L] z - 6 * тДШ[L] z ^ 2 + L.gтВВ / 2) x := by
      have h1 := L.analyticOnNhd_derivWeierstrassP _ hx
      have h2 := L.analyticOnNhd_weierstrassP _ hx
      fun_prop
    apply this.congr
    filter_upwards [L.isClosed_lattice.isOpen_compl.mem_nhds hx] with x hx
    simp_all [relationтВВ]

private lemma relationтВВ_eq_zero : L.relationтВВ = 0 := by
  ext x
  refine (Differentiable.eq_of_zLattice_periodic
    (fun x тЖж (L.analyticAt_relationтВВ x).differentiableAt) L.lattice
    (fun w hw z тЖж by lift w to L.lattice using hw; simp) x 0).trans (if_pos (by simp))

/-- The second derivative of the Weierstrass `тДШ`-function:
`тДШ''(z) = 6тДШ(z)┬▓ - gтВВ/2` away from the lattice. -/
theorem deriv_derivWeierstrassP {z : тДВ} (hz : z тИЙ L.lattice) :
    deriv тДШ'[L] z = 6 * тДШ[L] z ^ 2 - L.gтВВ / 2 := by
  have := congr($(L.relationтВВ_eq_zero) z)
  simp only [relationтВВ, if_neg hz, Pi.zero_apply] at this
  linear_combination this

/-- `тДШ'' = 6тДШ┬▓ - gтВВ/2`, in iterated-derivative form. -/
theorem iteratedDeriv_two_weierstrassP {z : тДВ} (hz : z тИЙ L.lattice) :
    iteratedDeriv 2 тДШ[L] z = 6 * тДШ[L] z ^ 2 - L.gтВВ / 2 := by
  rw [iteratedDeriv_succ, iteratedDeriv_one, deriv_weierstrassP]
  exact L.deriv_derivWeierstrassP hz

/-- `тДШ''' = 12тДШтДШ'`: differentiate `тДШ'' = 6тДШ┬▓ - gтВВ/2` on the open set `╬Ыс╢Ь`. -/
theorem iteratedDeriv_three_weierstrassP {z : тДВ} (hz : z тИЙ L.lattice) :
    iteratedDeriv 3 тДШ[L] z = 12 * тДШ[L] z * тДШ'[L] z := by
  rw [iteratedDeriv_succ]
  have heq : iteratedDeriv 2 тДШ[L] =с╢а[ЁЭУЭ z] fun w тЖж 6 * тДШ[L] w ^ 2 - L.gтВВ / 2 := by
    filter_upwards [L.isClosed_lattice.isOpen_compl.mem_nhds hz] with w hw
    exact L.iteratedDeriv_two_weierstrassP hw
  rw [heq.deriv_eq]
  have hP : HasDerivAt тДШ[L] (тДШ'[L] z) z := by
    rw [тЖР congr_fun L.deriv_weierstrassP z]
    exact (L.analyticOnNhd_weierstrassP z hz).differentiableAt.hasDerivAt
  have hd : HasDerivAt (fun w тЖж 6 * тДШ[L] w ^ 2 - L.gтВВ / 2)
      (6 * (2 * тДШ[L] z ^ (2 - 1) * тДШ'[L] z)) z :=
    ((hP.pow 2).const_mul 6).sub_const _
  rw [hd.deriv]
  ring

/-- `тДШтБЧ = 12тДШ'┬▓ + 12тДШ┬╖(6тДШ┬▓ - gтВВ/2)`: differentiate `тДШ''' = 12тДШтДШ'` on `╬Ыс╢Ь`. -/
theorem iteratedDeriv_four_weierstrassP {z : тДВ} (hz : z тИЙ L.lattice) :
    iteratedDeriv 4 тДШ[L] z =
      12 * тДШ'[L] z ^ 2 + 12 * тДШ[L] z * (6 * тДШ[L] z ^ 2 - L.gтВВ / 2) := by
  rw [iteratedDeriv_succ]
  have heq : iteratedDeriv 3 тДШ[L] =с╢а[ЁЭУЭ z] fun w тЖж 12 * тДШ[L] w * тДШ'[L] w := by
    filter_upwards [L.isClosed_lattice.isOpen_compl.mem_nhds hz] with w hw
    exact L.iteratedDeriv_three_weierstrassP hw
  rw [heq.deriv_eq]
  have hP : HasDerivAt тДШ[L] (тДШ'[L] z) z := by
    rw [тЖР congr_fun L.deriv_weierstrassP z]
    exact (L.analyticOnNhd_weierstrassP z hz).differentiableAt.hasDerivAt
  have hP' : HasDerivAt тДШ'[L] (deriv тДШ'[L] z) z :=
    (L.analyticOnNhd_derivWeierstrassP z hz).differentiableAt.hasDerivAt
  have hd : HasDerivAt (fun w тЖж 12 * тДШ[L] w * тДШ'[L] w)
      (12 * тДШ'[L] z * тДШ'[L] z + 12 * тДШ[L] z * deriv тДШ'[L] z) z :=
    (hP.const_mul 12).mul hP'
  rw [hd.deriv, L.deriv_derivWeierstrassP hz]
  ring

end SecondDerivative

/-! ### The addition theorem -/

section Addition

variable {zтВВ : тДВ}

/-- (Implementation) The defect of the addition theorem for `тДШ` at translation `zтВВ`,
as a function of `zтВБ`, extended by `0` on its polar locus `╬Ы тИк (╬Ы - zтВВ)`. For
`zтВВ тИЙ ╬Ы` it is constantly zero: see `PeriodPair.weierstrassP_add_sq`. -/
private def addRelation (zтВВ : тДВ) (z : тДВ) : тДВ :=
  letI := Classical.propDecidable
  if z тИИ L.lattice тИи z + zтВВ тИИ L.lattice then 0 else
    (тДШ[L] (z + zтВВ) + тДШ[L] z + тДШ[L] zтВВ) * (тДШ[L] z - тДШ[L] zтВВ) ^ 2
      - (тДШ'[L] z - тДШ'[L] zтВВ) ^ 2 / 4

/-- (Implementation) `z тЖж тДШ(z + c)` is meromorphic. -/
private lemma meromorphic_wP_add (c : тДВ) : Meromorphic (fun z тЖж тДШ[L] (z + c)) :=
  fun x тЖж (L.meromorphic_weierstrassP (x + c)).comp_analyticAt (g := fun z тЖж z + c) (by fun_prop)

@[local fun_prop]
private lemma meromorphic_addRelation : Meromorphic (L.addRelation zтВВ) := by
  intro x
  have h1 : MeromorphicAt (fun z тЖж тДШ[L] (z + zтВВ)) x := L.meromorphic_wP_add zтВВ x
  have h2 : MeromorphicAt тДШ[L] x := L.meromorphic_weierstrassP x
  have h3 : MeromorphicAt тДШ'[L] x := L.meromorphic_derivWeierstrassP x
  refine ((((h1.add h2).add (.const (тДШ[L] zтВВ) x)).mul
    ((h2.sub (.const (тДШ[L] zтВВ) x)).pow 2)).sub
    (((h3.sub (.const (тДШ'[L] zтВВ) x)).pow 2).div (.const 4 x))).congr ?_
  filter_upwards [self_mem_nhdsWithin,
    mem_nhdsWithin_of_mem_nhds (L.compl_lattice_sdiff_singleton_mem_nhds x),
    mem_nhdsWithin_of_mem_nhds ((continuous_add_const zтВВ).continuousAt.preimage_mem_nhds
      (L.compl_lattice_sdiff_singleton_mem_nhds (x + zтВВ)))] with w hw hw' hw''
  simp only [Set.mem_preimage] at hw''
  have hwx : w тЙа x := hw
  rw [addRelation, if_neg (show ┬м(w тИИ L.lattice тИи w + zтВВ тИИ L.lattice) from
    not_or.mpr тЯиfun h тЖж hw' тЯиh, hwxтЯй, fun h тЖж hw'' тЯиh, fun e тЖж hwx (add_right_cancel e)тЯйтЯй)]
  simp only [Pi.add_apply, Pi.sub_apply, Pi.mul_apply, Pi.div_apply, Pi.pow_apply]

@[local simp]
private lemma addRelation_add_coe (x : тДВ) (l : L.lattice) :
    L.addRelation zтВВ (x + l) = L.addRelation zтВВ x := by
  unfold addRelation
  rw [show x + (l : тДВ) + zтВВ = x + zтВВ + l from by ring, L.lattice.add_mem_iff_left l.2,
    L.lattice.add_mem_iff_left l.2]
  simp only [weierstrassP_add_coe, derivWeierstrassP_add_coe]

@[local simp]
private lemma addRelation_sub_coe (x : тДВ) (l : L.lattice) :
    L.addRelation zтВВ (x - l) = L.addRelation zтВВ x := by
  rw [тЖР L.addRelation_add_coe _ l, sub_add_cancel]

/-- (Implementation) Pole-clearing at `0` (locus `╬Ы`). -/
private lemma addRelation_mul_id_pow_six_eventuallyEq (hzтВВ : zтВВ тИЙ L.lattice) :
    (L.addRelation zтВВ * id ^ 6) =с╢а[nhds 0] fun z тЖж
      ((тДШ[L] (z + zтВВ) + тДШ[L] zтВВ) * z ^ 2 + тДШ[L - (0 : тДВ)] z * z ^ 2 + 1)
        * ((тДШ[L - (0 : тДВ)] z - тДШ[L] zтВВ) * z ^ 2 + 1) ^ 2
        - ((тДШ'[L - (0 : тДВ)] z - тДШ'[L] zтВВ) * z ^ 3 - 2) ^ 2 / 4 := by
  have hz2mem : {z : тДВ | z + zтВВ тИЙ L.lattice} тИИ nhds (0 : тДВ) :=
    (continuous_add_const zтВВ).continuousAt.preimage_mem_nhds
      (L.isClosed_lattice.isOpen_compl.mem_nhds (by simpa using hzтВВ))
  filter_upwards [L.compl_lattice_sdiff_singleton_mem_nhds 0, hz2mem] with z hz hz2L
  by_cases hz0 : z = 0
  ┬╖ subst hz0
    simp only [Pi.mul_apply, Pi.pow_apply, id_eq, addRelation, weierstrassPExcept_zero]
    norm_num
  have hzL : z тИЙ L.lattice := fun h тЖж hz тЯиh, hz0тЯй
  have hPz : тДШ[L] z = тДШ[L - (0 : тДВ)] z + 1 / z ^ 2 := by
    have := L.weierstrassPExcept_add (0 : L.lattice) z; simpa using this.symm
  have hP'z : тДШ'[L] z = тДШ'[L - (0 : тДВ)] z - 2 / z ^ 3 := by
    have := L.derivWeierstrassPExcept_sub (0 : L.lattice) z; simpa using this.symm
  simp only [Pi.mul_apply, Pi.pow_apply, id_eq]
  rw [addRelation, if_neg (not_or.mpr тЯиhzL, hz2LтЯй), hPz, hP'z]
  field_simp
  ring

/-- (Implementation) Derivatives of `z тЖж тДШ(z + zтВВ)` at `0` are those of `тДШ` at `zтВВ`. -/
private lemma iteratedDeriv_wP_add_zero (n : тДХ) :
    iteratedDeriv n (fun z тЖж тДШ[L] (z + zтВВ)) 0 = iteratedDeriv n тДШ[L] zтВВ := by
  simp [iteratedDeriv_comp_add_const]

/-- (Implementation) `z тЖж тДШ(z + zтВВ)` is analytic at `0` when `zтВВ тИЙ ╬Ы`. -/
private lemma analyticAt_wP_add_zero (hzтВВ : zтВВ тИЙ L.lattice) :
    AnalyticAt тДВ (fun z тЖж тДШ[L] (z + zтВВ)) 0 :=
  (L.analyticOnNhd_weierstrassP zтВВ hzтВВ).comp_of_eq (by fun_prop) (zero_add zтВВ)

private lemma analyticAt_addRelation_mul_id_pow_six (hzтВВ : zтВВ тИЙ L.lattice) :
    AnalyticAt тДВ (L.addRelation zтВВ * id ^ 6) 0 := by
  refine .congr ?_ (L.addRelation_mul_id_pow_six_eventuallyEq hzтВВ).symm
  have hA := L.analyticAt_wP_add_zero hzтВВ
  fun_prop

attribute [local fun_prop] AnalyticAt.contDiffAt in
private lemma analyticAt_addRelation_zero (hzтВВ : zтВВ тИЙ L.lattice) :
    AnalyticAt тДВ (L.addRelation zтВВ) 0 := by
  have hA := L.analyticAt_wP_add_zero hzтВВ
  have hAC : тИА n : WithTop тДХтИЮ, ContDiffAt тДВ n (fun z тЖж тДШ[L] (z + zтВВ)) 0 := fun _ тЖж hA.contDiffAt
  have hDE : тДШ'[L] zтВВ ^ 2 = 4 * тДШ[L] zтВВ ^ 3 - 60 * L.G 4 * тДШ[L] zтВВ - 140 * L.G 6 := by
    have := L.derivWeierstrassP_sq zтВВ hzтВВ; simpa [gтВВ, gтВГ] using this
  have e0 : iteratedDeriv 0 тДШ[L] zтВВ = тДШ[L] zтВВ := rfl
  have e1 : iteratedDeriv 1 тДШ[L] zтВВ = тДШ'[L] zтВВ := by
    rw [iteratedDeriv_one, congr_fun L.deriv_weierstrassP]
  have e2 : iteratedDeriv 2 тДШ[L] zтВВ = 6 * тДШ[L] zтВВ ^ 2 - L.gтВВ / 2 :=
    L.iteratedDeriv_two_weierstrassP hzтВВ
  have e3 : iteratedDeriv 3 тДШ[L] zтВВ = 12 * тДШ[L] zтВВ * тДШ'[L] zтВВ :=
    L.iteratedDeriv_three_weierstrassP hzтВВ
  have e4 : iteratedDeriv 4 тДШ[L] zтВВ =
      12 * тДШ'[L] zтВВ ^ 2 + 12 * тДШ[L] zтВВ * (6 * тДШ[L] zтВВ ^ 2 - L.gтВВ / 2) :=
    L.iteratedDeriv_four_weierstrassP hzтВВ
  have horder : meromorphicOrderAt ((id : тДВ тЖТ тДВ) ^ 6) 0 = 6 := by
    have he : ((id : тДВ тЖТ тДВ) ^ 6) = ((┬╖ - (0 : тДВ)) ^ 6 : тДВ тЖТ тДВ) := by ext z; simp
    rw [he]; simpa using meromorphicOrderAt_pow_id_sub_const (x := (0 : тДВ)) (n := 6)
  refine analyticAt_of_mul_uniformiser (by fun_prop) (by fun_prop) (by simp [addRelation])
    horder (L.analyticAt_addRelation_mul_id_pow_six hzтВВ) fun i hiтВБ тЖж ?_
  rw [(L.addRelation_mul_id_pow_six_eventuallyEq hzтВВ).iteratedDeriv_eq]
  simp_rw [pow_succ (_ + _), pow_succ (_ - _), pow_zero, one_mul]
  simp (discharger := fun_prop) only [iteratedDeriv_fun_add, iteratedDeriv_fun_sub,
    iteratedDeriv_fun_mul, iteratedDeriv_const, iteratedDeriv_fun_pow_zero,
    iteratedDeriv_div_const, iteratedDeriv_derivWeierstrassPExcept_self,
    iteratedDeriv_weierstrassPExcept_self, L.iteratedDeriv_wP_add_zero]
  interval_cases i <;>
    simp only [Finset.sum_range_succ, Finset.sum_range_zero, e0, e1, e2, e3, e4,
      weierstrassPExcept_zero, sumInvPow_zero, L.G_eq_zero_of_odd 3 (by decide),
      L.G_eq_zero_of_odd 5 (by decide), gтВВ, Nat.choose, Nat.factorial,
      Nat.choose_self] <;>
    push_cast <;>
    ring_nf
  linear_combination 180 * hDE

/-- (Implementation) Pole-clearing at `-zтВВ` (locus `╬Ы - zтВВ`). -/
private lemma addRelation_mul_add_sq_eventuallyEq (hzтВВ : zтВВ тИЙ L.lattice) :
    (L.addRelation zтВВ * fun z тЖж (z + zтВВ) ^ 2) =с╢а[nhds (-zтВВ)] fun z тЖж
      (тДШ[L - (0 : тДВ)] (z + zтВВ) * (z + zтВВ) ^ 2 + 1) * (тДШ[L] z - тДШ[L] zтВВ) ^ 2
        + ((тДШ[L] z + тДШ[L] zтВВ) * (тДШ[L] z - тДШ[L] zтВВ) ^ 2 - (тДШ'[L] z - тДШ'[L] zтВВ) ^ 2 / 4)
          * (z + zтВВ) ^ 2 := by
  have hnegzтВВ : -zтВВ тИЙ L.lattice := fun h тЖж hzтВВ (by simpa using neg_mem h)
  have hmem2 : (fun z : тДВ тЖж z + zтВВ) тБ╗┬╣' (тЖСL.lattice \ {0})с╢Ь тИИ nhds (-zтВВ) :=
    (continuous_add_const zтВВ).continuousAt.preimage_mem_nhds
      (by simpa using L.compl_lattice_sdiff_singleton_mem_nhds 0)
  filter_upwards [L.isClosed_lattice.isOpen_compl.mem_nhds hnegzтВВ, hmem2] with z hz1 hz2
  simp only [Set.mem_preimage] at hz2
  have hzL : z тИЙ L.lattice := hz1
  by_cases hz0 : z + zтВВ = 0
  ┬╖ have hze : z = -zтВВ := by linear_combination hz0
    subst hze
    simp only [Pi.mul_apply, neg_add_cancel, addRelation, weierstrassPExcept_zero,
      weierstrassP_neg]
    norm_num
  have hz2L : z + zтВВ тИЙ L.lattice := fun h тЖж hz2 тЯиh, hz0тЯй
  have hP : тДШ[L] (z + zтВВ) = тДШ[L - (0 : тДВ)] (z + zтВВ) + 1 / (z + zтВВ) ^ 2 := by
    have := L.weierstrassPExcept_add (0 : L.lattice) (z + zтВВ); simpa using this.symm
  simp only [Pi.mul_apply]
  rw [addRelation, if_neg (not_or.mpr тЯиhzL, hz2LтЯй), hP]
  field_simp
  ring

private lemma iteratedDeriv_wPExcept_add_negZ2 (n : тДХ) :
    iteratedDeriv n (fun z тЖж тДШ[L - (0 : тДВ)] (z + zтВВ)) (-zтВВ) = iteratedDeriv n тДШ[L - (0 : тДВ)] 0 := by
  simp [iteratedDeriv_comp_add_const]

private lemma iteratedDeriv_add_sq_negZ2 (n : тДХ) :
    iteratedDeriv n (fun z : тДВ тЖж (z + zтВВ) ^ 2) (-zтВВ) = iteratedDeriv n (┬╖ ^ 2 : тДВ тЖТ тДВ) 0 := by
  have h := congrFun (iteratedDeriv_comp_add_const n (┬╖ ^ 2 : тДВ тЖТ тДВ) zтВВ) (-zтВВ)
  simpa using h

private lemma analyticAt_addRelation_mul_add_sq (hzтВВ : zтВВ тИЙ L.lattice) :
    AnalyticAt тДВ (L.addRelation zтВВ * fun z тЖж (z + zтВВ) ^ 2) (-zтВВ) := by
  have hnegzтВВ : -zтВВ тИЙ L.lattice := fun h тЖж hzтВВ (by simpa using neg_mem h)
  refine .congr ?_ (L.addRelation_mul_add_sq_eventuallyEq hzтВВ).symm
  have hP := L.analyticOnNhd_weierstrassP (-zтВВ) hnegzтВВ
  have hP' := L.analyticOnNhd_derivWeierstrassP (-zтВВ) hnegzтВВ
  have hEx : AnalyticAt тДВ (fun z тЖж тДШ[L - (0 : тДВ)] (z + zтВВ)) (-zтВВ) :=
    (L.analyticAt_weierstrassPExcept 0).comp_of_eq (by fun_prop) (by simp)
  fun_prop

attribute [local fun_prop] AnalyticAt.contDiffAt in
private lemma analyticAt_addRelation_negZ2 (hzтВВ : zтВВ тИЙ L.lattice) :
    AnalyticAt тДВ (L.addRelation zтВВ) (-zтВВ) := by
  have hnegzтВВ : -zтВВ тИЙ L.lattice := fun h тЖж hzтВВ (by simpa using neg_mem h)
  have hPc : тИА n : WithTop тДХтИЮ, ContDiffAt тДВ n тДШ[L] (-zтВВ) :=
    fun _ тЖж (L.analyticOnNhd_weierstrassP (-zтВВ) hnegzтВВ).contDiffAt
  have hP'c : тИА n : WithTop тДХтИЮ, ContDiffAt тДВ n тДШ'[L] (-zтВВ) :=
    fun _ тЖж (L.analyticOnNhd_derivWeierstrassP (-zтВВ) hnegzтВВ).contDiffAt
  have hExc : тИА n : WithTop тДХтИЮ, ContDiffAt тДВ n (fun z тЖж тДШ[L - (0 : тДВ)] (z + zтВВ)) (-zтВВ) :=
    fun _ тЖж ((L.analyticAt_weierstrassPExcept 0).comp_of_eq (by fun_prop) (by simp)).contDiffAt
  have p0 : iteratedDeriv 0 тДШ[L] (-zтВВ) = тДШ[L] zтВВ := by simp
  have p1 : iteratedDeriv 1 тДШ[L] (-zтВВ) = -тДШ'[L] zтВВ := by
    rw [iteratedDeriv_one, congr_fun L.deriv_weierstrassP]; simp
  have p2 : iteratedDeriv 2 тДШ[L] (-zтВВ) = 6 * тДШ[L] zтВВ ^ 2 - L.gтВВ / 2 := by
    rw [L.iteratedDeriv_two_weierstrassP hnegzтВВ]; simp
  have q0 : iteratedDeriv 0 тДШ'[L] (-zтВВ) = -тДШ'[L] zтВВ := by simp
  have q1 : iteratedDeriv 1 тДШ'[L] (-zтВВ) = 6 * тДШ[L] zтВВ ^ 2 - L.gтВВ / 2 := by
    rw [iteratedDeriv_one, L.deriv_derivWeierstrassP hnegzтВВ]; simp
  have h3 : iteratedDeriv 3 тДШ[L] (-zтВВ) = iteratedDeriv 2 тДШ'[L] (-zтВВ) := by
    rw [iteratedDeriv_succ', L.deriv_weierstrassP]
  have q2 : iteratedDeriv 2 тДШ'[L] (-zтВВ) = -(12 * тДШ[L] zтВВ * тДШ'[L] zтВВ) := by
    rw [тЖР h3, L.iteratedDeriv_three_weierstrassP hnegzтВВ]
    simp only [weierstrassP_neg, derivWeierstrassP_neg]; ring
  have horder : meromorphicOrderAt (fun z : тДВ тЖж (z + zтВВ) ^ 2) (-zтВВ) = 2 := by
    have he : (fun z : тДВ тЖж (z + zтВВ) ^ 2) = ((┬╖ - -zтВВ) ^ 2 : тДВ тЖТ тДВ) := by
      ext z; simp [sub_neg_eq_add]
    rw [he]; simpa using meromorphicOrderAt_pow_id_sub_const (x := (-zтВВ : тДВ)) (n := 2)
  refine analyticAt_of_mul_uniformiser (by fun_prop) (by fun_prop) (by simp [addRelation])
    horder (L.analyticAt_addRelation_mul_add_sq hzтВВ) fun i hiтВБ тЖж ?_
  rw [(L.addRelation_mul_add_sq_eventuallyEq hzтВВ).iteratedDeriv_eq]
  simp_rw [pow_succ (_ - _), pow_zero, one_mul]
  simp (discharger := fun_prop) only [iteratedDeriv_fun_add, iteratedDeriv_fun_sub,
    iteratedDeriv_fun_mul, iteratedDeriv_const, iteratedDeriv_div_const,
    iteratedDeriv_fun_pow_zero, iteratedDeriv_weierstrassPExcept_self,
    L.iteratedDeriv_wPExcept_add_negZ2, iteratedDeriv_add_sq_negZ2]
  interval_cases i <;>
    simp only [Finset.sum_range_succ, Finset.sum_range_zero, p0, p1, p2, q0, q1, q2,
      weierstrassPExcept_zero, sumInvPow_zero, gтВВ, Nat.choose, Nat.factorial,
      Nat.choose_self] <;>
    push_cast <;>
    ring_nf

private lemma analyticAt_addRelation (hzтВВ : zтВВ тИЙ L.lattice) (x : тДВ) :
    AnalyticAt тДВ (L.addRelation zтВВ) x := by
  by_cases hx : x тИИ L.lattice
  ┬╖ have key : (fun z тЖж L.addRelation zтВВ (z - x)) = L.addRelation zтВВ := by
      ext a; exact L.addRelation_sub_coe a тЯиx, hxтЯй
    rw [тЖР key]
    exact (L.analyticAt_addRelation_zero hzтВВ).comp_of_eq (by fun_prop) (by ring)
  by_cases hx2 : x + zтВВ тИИ L.lattice
  ┬╖ have key : (fun z тЖж L.addRelation zтВВ (z - (x + zтВВ))) = L.addRelation zтВВ := by
      ext a; exact L.addRelation_sub_coe a тЯиx + zтВВ, hx2тЯй
    rw [тЖР key]
    exact (L.analyticAt_addRelation_negZ2 hzтВВ).comp_of_eq (by fun_prop) (by ring)
  ┬╖ have hnx : x тИЙ L.lattice := hx
    have hnx2 : x + zтВВ тИЙ L.lattice := hx2
    have hAx : AnalyticAt тДВ (fun z тЖж тДШ[L] (z + zтВВ)) x :=
      (L.analyticOnNhd_weierstrassP (x + zтВВ) hnx2).comp_of_eq (by fun_prop) rfl
    have hP := L.analyticOnNhd_weierstrassP x hnx
    have hP' := L.analyticOnNhd_derivWeierstrassP x hnx
    have hsmooth : AnalyticAt тДВ (fun z тЖж (тДШ[L] (z + zтВВ) + тДШ[L] z + тДШ[L] zтВВ)
        * (тДШ[L] z - тДШ[L] zтВВ) ^ 2 - (тДШ'[L] z - тДШ'[L] zтВВ) ^ 2 / 4) x := by fun_prop
    have hopen : IsOpen {w : тДВ | w тИЙ L.lattice тИз w + zтВВ тИЙ L.lattice} := by
      rw [Set.setOf_and]
      exact (L.isClosed_lattice.isOpen_compl).inter
        ((continuous_add_const zтВВ).isOpen_preimage _ L.isClosed_lattice.isOpen_compl)
    apply hsmooth.congr
    filter_upwards [hopen.mem_nhds тЯиhnx, hnx2тЯй] with w hw
    rw [addRelation, if_neg (show ┬м(w тИИ L.lattice тИи w + zтВВ тИИ L.lattice) from
      not_or.mpr тЯиhw.1, hw.2тЯй)]

private lemma addRelation_eq_zero (hzтВВ : zтВВ тИЙ L.lattice) : L.addRelation zтВВ = 0 := by
  ext x
  refine (Differentiable.eq_of_zLattice_periodic
    (fun x тЖж (L.analyticAt_addRelation hzтВВ x).differentiableAt) L.lattice
    (fun w hw z тЖж by lift w to L.lattice using hw; simp) x 0).trans (if_pos (by simp))

/-- **The addition theorem for the Weierstrass `тДШ`-function**, in polynomial form: for
`zтВБ, zтВВ, zтВБ + zтВВ` off the lattice,

`(тДШ(zтВБ+zтВВ) + тДШ(zтВБ) + тДШ(zтВВ)) ┬╖ (тДШ(zтВБ) - тДШ(zтВВ))┬▓ = (тДШ'(zтВБ) - тДШ'(zтВВ))┬▓ / 4`.

No `тДШ(zтВБ) тЙа тДШ(zтВВ)` hypothesis is needed in this form; dividing by `(тДШ(zтВБ) - тДШ(zтВВ))┬▓`
when nonzero recovers the classical
`тДШ(zтВБ+zтВВ) = ┬╝((тДШ'(zтВБ)-тДШ'(zтВВ))/(тДШ(zтВБ)-тДШ(zтВВ)))┬▓ - тДШ(zтВБ) - тДШ(zтВВ)`. -/
theorem weierstrassP_add_sq (zтВБ : тДВ) (hтВБ : zтВБ тИЙ L.lattice) (hтВВ : zтВВ тИЙ L.lattice)
    (hтВБтВВ : zтВБ + zтВВ тИЙ L.lattice) :
    (тДШ[L] (zтВБ + zтВВ) + тДШ[L] zтВБ + тДШ[L] zтВВ) * (тДШ[L] zтВБ - тДШ[L] zтВВ) ^ 2
      = (тДШ'[L] zтВБ - тДШ'[L] zтВВ) ^ 2 / 4 := by
  have := congr($(L.addRelation_eq_zero hтВВ) zтВБ)
  simp only [addRelation, if_neg (not_or.mpr тЯиhтВБ, hтВБтВВтЯй), Pi.zero_apply] at this
  linear_combination this

/-- The `zтВБ`-derivative of the addition theorem: the polynomial identity determining
`тДШ'(zтВБ+zтВВ)┬╖(тДШ(zтВБ)-тДШ(zтВВ))┬▓`. Obtained by differentiating `weierstrassP_add_sq` in `zтВБ`
on the open set where it holds, using `тДШ'' = 6тДШ┬▓ - gтВВ/2`. -/
theorem derivWeierstrassP_add_sq (zтВБ : тДВ) (hтВБ : zтВБ тИЙ L.lattice) (hтВВ : zтВВ тИЙ L.lattice)
    (hтВБтВВ : zтВБ + zтВВ тИЙ L.lattice) :
    тДШ'[L] (zтВБ + zтВВ) * (тДШ[L] zтВБ - тДШ[L] zтВВ) ^ 2
      = (тДШ'[L] zтВБ - тДШ'[L] zтВВ) * (6 * тДШ[L] zтВБ ^ 2 - L.gтВВ / 2) / 2
        - тДШ'[L] zтВБ * (тДШ[L] zтВБ - тДШ[L] zтВВ) ^ 2
        - 2 * (тДШ[L] (zтВБ + zтВВ) + тДШ[L] zтВБ + тДШ[L] zтВВ) * (тДШ[L] zтВБ - тДШ[L] zтВВ) * тДШ'[L] zтВБ := by
  -- The addition identity holds on the open set where `z, z + zтВВ тИЙ ╬Ы`, so its two sides
  -- (as functions of `zтВБ`) agree near `zтВБ`, hence have equal derivatives.
  have hEq : (fun z тЖж (тДШ[L] (z + zтВВ) + тДШ[L] z + тДШ[L] zтВВ) * (тДШ[L] z - тДШ[L] zтВВ) ^ 2)
      =с╢а[ЁЭУЭ zтВБ] fun z тЖж (тДШ'[L] z - тДШ'[L] zтВВ) ^ 2 / 4 := by
    have hmem2 : {z : тДВ | z + zтВВ тИЙ L.lattice} тИИ ЁЭУЭ zтВБ :=
      (continuous_add_const zтВВ).continuousAt.preimage_mem_nhds
        (L.isClosed_lattice.isOpen_compl.mem_nhds hтВБтВВ)
    filter_upwards [L.isClosed_lattice.isOpen_compl.mem_nhds hтВБ, hmem2] with z hz hz'
    exact L.weierstrassP_add_sq z hz hтВВ hz'
  have hP1 : HasDerivAt тДШ[L] (тДШ'[L] zтВБ) zтВБ := by
    rw [тЖР congr_fun L.deriv_weierstrassP zтВБ]
    exact (L.analyticOnNhd_weierstrassP zтВБ hтВБ).differentiableAt.hasDerivAt
  have hP12 : HasDerivAt тДШ[L] (тДШ'[L] (zтВБ + zтВВ)) (zтВБ + zтВВ) := by
    rw [тЖР congr_fun L.deriv_weierstrassP (zтВБ + zтВВ)]
    exact (L.analyticOnNhd_weierstrassP (zтВБ + zтВВ) hтВБтВВ).differentiableAt.hasDerivAt
  have hP1' : HasDerivAt тДШ'[L] (6 * тДШ[L] zтВБ ^ 2 - L.gтВВ / 2) zтВБ := by
    rw [тЖР L.deriv_derivWeierstrassP hтВБ]
    exact (L.analyticOnNhd_derivWeierstrassP zтВБ hтВБ).differentiableAt.hasDerivAt
  have hA : HasDerivAt (fun z тЖж тДШ[L] (z + zтВВ)) (тДШ'[L] (zтВБ + zтВВ)) zтВБ :=
    hP12.comp_add_const zтВБ zтВВ
  have hF : HasDerivAt (fun z тЖж (тДШ[L] (z + zтВВ) + тДШ[L] z + тДШ[L] zтВВ) * (тДШ[L] z - тДШ[L] zтВВ) ^ 2)
      ((тДШ'[L] (zтВБ + zтВВ) + тДШ'[L] zтВБ) * (тДШ[L] zтВБ - тДШ[L] zтВВ) ^ 2
        + (тДШ[L] (zтВБ + zтВВ) + тДШ[L] zтВБ + тДШ[L] zтВВ)
          * (2 * (тДШ[L] zтВБ - тДШ[L] zтВВ) ^ (2 - 1) * тДШ'[L] zтВБ)) zтВБ :=
    ((hA.add hP1).add_const (тДШ[L] zтВВ)).mul ((hP1.sub_const (тДШ[L] zтВВ)).pow 2)
  have hG : HasDerivAt (fun z тЖж (тДШ'[L] z - тДШ'[L] zтВВ) ^ 2 / 4)
      (2 * (тДШ'[L] zтВБ - тДШ'[L] zтВВ) ^ (2 - 1) * (6 * тДШ[L] zтВБ ^ 2 - L.gтВВ / 2) / 4) zтВБ :=
    ((hP1'.sub_const (тДШ'[L] zтВВ)).pow 2).div_const 4
  have key := hEq.deriv_eq
  rw [hF.deriv, hG.deriv] at key
  linear_combination key

end Addition

end PeriodPair

module

public import Mathlib.FieldTheory.SeparableDegree

/-!
# A field extension generated by a separable element is separable

Material for `Mathlib.FieldTheory.SeparableDegree`.
-/

@[expose] public section

/-- A field extension generated by a single separable element is separable. -/
theorem Algebra.IsSeparable.of_isSeparable_of_adjoin_eq_top {F E : Type*} [Field F] [Field E]
    [Algebra F E] {x : E} (hx : IsSeparable F x)
    (hgen : IntermediateField.adjoin F {x} = ⊤) : Algebra.IsSeparable F E := by
  have : Algebra.IsSeparable F (⊤ : IntermediateField F E) := by
    rw [← hgen]
    exact (IntermediateField.isSeparable_adjoin_simple_iff_isSeparable _ _).mpr hx
  exact AlgEquiv.Algebra.isSeparable IntermediateField.topEquiv

end

lemma adicCompletionIntegers.exists_bijOn_mk_span
    (h╬▒ : ╬▒ тЙа 0) : тИГ (s : Finset (v.adicCompletionIntegers F)),
    Set.BijOn (Ideal.Quotient.mk (Ideal.span {╬▒})) s .univ := by
  have : Finite (v.adicCompletionIntegers F тз╕ Ideal.span {╬▒}) :=
    adicCompletionIntegers.finite_quotient _ (by simpa)
  cases nonempty_fintype (v.adicCompletionIntegers F тз╕ Ideal.span {╬▒})
  classical
  refine тЯи(Finset.univ : Finset (v.adicCompletionIntegers F тз╕ Ideal.span {╬▒})).image
    Quotient.out, ?_тЯй
  rw [Finset.coe_image, тЖР Set.bijOn_comp_iff Quotient.out_injective.injOn]
  simp

open AbstractHeckeOperator in
lemma U_mul_U (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvQ : v тИИ ЁЭТо.Q) (╬▒ ╬▓ : v.adicCompletionIntegers F) (h╬▒ : ╬▒ тЙа 0) (h╬▓ : ╬▓ тЙа 0) :
    U D M ЁЭТо v hvQ ╬▒ h╬▒ * U D M ЁЭТо v hvQ ╬▓ h╬▓ =
      U D M ЁЭТо v hvQ (╬▒ * ╬▓) (by simp [h╬▒, h╬▓]) := by
  classical
  ext x : 2
  obtain тЯиs, hsтЯй := adicCompletionIntegers.exists_bijOn_mk_span ╬▒ h╬▒
  obtain тЯиt, htтЯй := adicCompletionIntegers.exists_bijOn_mk_span ╬▓ h╬▓
  simp only [Module.End.mul_apply]
  rw [U_apply D ЁЭТо v hvQ ╬▒ h╬▒ _ s hs, U_apply D ЁЭТо v hvQ ╬▓ h╬▓ _ t ht]
  have HтВА : Set.BijOn (Ideal.Quotient.mk (Ideal.span {╬▒ * ╬▓}) тИШ
      fun ab тЖж ╬▒ * ab.2 + ab.1) (тЖСs ├Ч╦в тЖСt) Set.univ := by
    refine тЯиby simp, ?_, ?_тЯй
    ┬╖ rintro тЯиaтВБ, bтВБтЯй тЯиhaтВБ, hbтВБтЯй тЯиaтВВ, bтВВтЯй тЯиhaтВВ, hbтВВтЯй e
      simp only [Function.comp_apply, Ideal.mem_span_singleton,
        Ideal.Quotient.mk_eq_mk_iff_sub_mem] at e
      rw [add_sub_add_comm, тЖР mul_sub] at e
      obtain rfl := hs.2.1 haтВБ haтВВ (by simpa [Ideal.mem_span_singleton,
        Ideal.Quotient.mk_eq_mk_iff_sub_mem, dvd_add_right] using (dvd_mul_right _ _).trans e)
      obtain rfl := ht.2.1 hbтВБ hbтВВ (by simpa [Ideal.mem_span_singleton,
        Ideal.Quotient.mk_eq_mk_iff_sub_mem, mul_dvd_mul_iff_left, h╬▒] using e)
      rfl
    ┬╖ rintro a -
      obtain тЯиa, rflтЯй := Ideal.Quotient.mk_surjective a
      obtain тЯиsaa, hsa, hsaaтЯй := hs.2.2 (Set.mem_univ (Ideal.Quotient.mk _ a))
      simp only [Ideal.mem_span_singleton, Ideal.Quotient.mk_eq_mk_iff_sub_mem] at hsaa
      obtain тЯиb, hbтЯй := hsaa
      obtain тЯиta, hta, htaaтЯй := ht.2.2 (Set.mem_univ (Ideal.Quotient.mk _ (-b)))
      simp only [Ideal.Quotient.mk_eq_mk_iff_sub_mem, sub_neg_eq_add,
        Ideal.mem_span_singleton] at htaa
      refine тЯитЯи_, _тЯй, тЯиhsa, htaтЯй, ?_тЯй
      simpa [add_sub_assoc, hb, тЖР mul_add, mul_dvd_mul_iff_left, h╬▒,
        Ideal.mem_span_singleton, Ideal.Quotient.mk_eq_mk_iff_sub_mem, -map_add]
  rw [U_apply D ЁЭТо v hvQ (╬▒ * ╬▓) (by simp [h╬▒, h╬▓]) _ ((s ├Ч╦в t).image fun ab тЖж ╬▒ * ab.2 + ab.1)]
  ┬╖ simp only [Finset.smul_sum, тЖР mul_smul]
    rw [Finset.sum_image (by simpa using HтВА.injOn.of_comp), Finset.sum_product]
    refine Finset.sum_congr rfl fun a ha тЖж Finset.sum_congr rfl fun b hb тЖж ?_
    congr 1
    ext i j
    fin_cases i <;> fin_cases j <;>
      simp [HeckeOperator.Local.GL2.unipotentMulDiag, Matrix.mul_apply,
        Matrix.GeneralLinearGroup.GL2.unipotent_def,
        HeckeOperator.Local.GL2.diag, Matrix.vecMul_eq_sum]
  ┬╖ simp only [Finset.coe_image, Finset.coe_product]
    rwa [тЖР Set.bijOn_comp_iff HтВА.injOn.of_comp]


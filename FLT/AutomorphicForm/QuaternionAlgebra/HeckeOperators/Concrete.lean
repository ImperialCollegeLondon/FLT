instance [FaithfulSMul R M] :
    FaithfulSMul (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D M) := by
  refine тЯиfun {T T'} H тЖж ?_тЯй
  wlog hT' : T' = 0 generalizing T T'
  ┬╖ refine sub_eq_zero.mp (this (fun a тЖж by simp [H, sub_smul]) rfl)
  subst hT'
  apply Subtype.val_injective
  refine DFunLike.ext'_iff.mpr ?_
  ext f g
  refine FaithfulSMul.eq_of_smul_eq_smul (╬▒ := M) fun m тЖж ?_
  have := H ((UтВБ ЁЭТо).toStruct.formMap (S := R) _ (LinearMap.toSpanSingleton R M m) f)
  simpa [тЖР smul_eq_apply, тЖР formMap_smul] using congr(($this).1 g)


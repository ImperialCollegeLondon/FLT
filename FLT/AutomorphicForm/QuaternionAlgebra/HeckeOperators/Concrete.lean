open QuotientGroup in
lemma _root_.QuotientGroup.exists_bijOn_mk_image_mul_singleton
    {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (U : Subgroup G) (hOpen : IsOpen (X := G) U) (hCompact : IsCompact (X := G) U) (g : G) :
    тИГ s : Finset G,
      Set.BijOn QuotientGroup.mk (s : Set G) (QuotientGroup.mk '' (U * {g}) : Set (G тз╕ U)) := by
  have H : (QuotientGroup.mk '' (U * {g}) : Set (G тз╕ U)).Finite :=
    QuotientGroup.mk_image_finite_of_compact_of_open hCompact hOpen
  refine тЯи(H.image Quotient.out).toFinset, ?_тЯй
  simp only [Set.Finite.coe_toFinset]
  nth_rw 2 [тЖР Set.image_id (QuotientGroup.mk '' _)]
  refine Set.bijOn_image_image (f := id) (by simp) (Set.bijOn_id _) ?_
  rw [Set.injOn_image_iff Quotient.out_injective.injOn]
  simp

open scoped Pointwise in
lemma LocalLevelStruct.heckeOperator_eq_finsetSum (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (g : GLтВВ(v.adicCompletion F)) (s : Finset GLтВВ(v.adicCompletion F))
    (hs : Set.BijOn QuotientGroup.mk (s : Set GLтВВ(v.adicCompletion F))
        (QuotientGroup.mk '' (тДТ.US v * {g}) : Set (GLтВВ(v.adicCompletion F) тз╕ тДТ.US v)))
    (f : тДТ.toStruct.form D M) :
    (тДТ.heckeOperator D M v hv g f).1 = тИС i тИИ s, i тАв f.1 := by
  ext g
  dsimp [heckeOperator]
  rw [AbstractHeckeOperator.heckeOperator_eq_finsetSum _ _ s hs]
  simp

variable (D S M) in
/-- Hecke operators on `S(U, ╧З)` given by a local element `GLтВВ(Fс╡е)`. -/
noncomputable
abbrev LocalLevelStruct.heckeOperatorL (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (g : GLтВВ(v.adicCompletion F)) [SMulCommClass R S M] :
    Module.End S (тДТ.toStruct.form D M) where
  __ := тДТ.heckeOperator D M v hv g
  map_smul' m x := by
    let f :=
      AbstractHeckeOperator.heckeOperator g (тДТ.US v) (тДТ.US v)
      (R := S) (A := WeightTwoAutomorphicForm F D M)
      (QuotientGroup.mk_image_finite_of_compact_of_open (тДТ.isCompact_US _) (тДТ.isOpen_US _))
    ext1
    change (f _).1 = (m тАв f _).1
    convert congr($(f.map_smul _ _).1)
    rfl

set_option backward.isDefEq.respectTransparency false in
lemma LocalLevelStruct.heckeOperator_eq_of_mem_normalizer
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (g : GLтВВ(v.adicCompletion F)) (hg : g тИИ Subgroup.normalizer (тДТ.US v)) (x) :
    (тДТ.heckeOperator D M v hv g x).1 = g тАв x := by

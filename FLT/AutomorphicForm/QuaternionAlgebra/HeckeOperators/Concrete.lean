variable (M) in
/-- The Hecke operator U_{v,╬▒} associated to the matrix (╬▒ 0;0 1) at v,
considered as an R-linear map from R-valued quaternionic weight 2
automorphic forms of level U_1(S). Here ╬▒ is a nonzero element of ЁЭУЮс╡е.
We do not demand the condition v тИИ S, the bad primes, but this operator
should only be used in this setting. See also `T r v` for the good primes.
-/
noncomputable def U (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvQ : v тИИ ЁЭТо.Q) (╬▒ : v.adicCompletionIntegers F) (h╬▒ : ╬▒ тЙа 0) :
  Module.End R ((UтВБ ЁЭТо).toStruct.form D M) :=
  (UтВБ ЁЭТо).heckeOperator _ _ v (by simp [UтВБ_╧З, hvQ]; rfl)
    (Matrix.GeneralLinearGroup.diagonal ![.mk0 ╬▒.1 (by simpa), 1])

@[simp]
lemma U_smul [SMulCommClass R S M]
    (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvQ : v тИИ ЁЭТо.Q) (╬▒ : v.adicCompletionIntegers F) (h╬▒ : ╬▒ тЙа 0) (r : S)
    (f : (UтВБ ЁЭТо).toStruct.form D M) : U D M ЁЭТо v hvQ ╬▒ h╬▒ (r тАв f) = r тАв U D M ЁЭТо v hvQ ╬▒ h╬▒ f :=
  ((UтВБ ЁЭТо).heckeOperatorL _ _ _ v (by simp [UтВБ_╧З, hvQ]; rfl)
    (Matrix.GeneralLinearGroup.diagonal ![.mk0 ╬▒.1 (by simpa), 1])).map_smul r f

lemma U_apply (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvQ : v тИИ ЁЭТо.Q) (╬▒ : v.adicCompletionIntegers F) (h╬▒ : ╬▒ тЙа 0) (x)
    (s : Finset (v.adicCompletionIntegers F))
    (hs : Set.BijOn (Ideal.Quotient.mk (Ideal.span {╬▒})) s .univ) :
    (U D M ЁЭТо v hvQ ╬▒ h╬▒ x).1 =
      тИС i тИИ s, HeckeOperator.Local.GL2.unipotentMulDiag
        (.mk0 тЖС╬▒ (by simp [h╬▒])) i.1 тАв x.1 := by
  classical
  dsimp [U, LocalLevelStruct.heckeOperator]
  refine (AbstractHeckeOperator.heckeOperator_eq_finsetSum _ _
    (s.image (HeckeOperator.Local.GL2.unipotentMulDiag
      (.mk0 тЖС╬▒ (by simp [h╬▒])) тИШ (тЖС))) ?_).trans ?_
  ┬╖ simp only [Finset.coe_image, Function.comp_apply]
    rw [тЖР Set.bijOn_comp_iff]
    ┬╖ generalize hU : (UтВБ ЁЭТо).US v = U
      simp only [UтВБ, MulEquiv.toMonoidHom_eq_coe, hvQ, тЖУreduceIte] at hU
      subst hU
      convert! (HeckeOperator.Local.bijOn_unipotentMulDiagU1 v p ╬▒ h╬▒).comp hs using 4
      ext i j; fin_cases i <;> fin_cases j <;>
        simp [Matrix.GeneralLinearGroup.diagonal, HeckeOperator.Local.GL2.diag]
    ┬╖ exact ((HeckeOperator.Local.GL2.unipotentMulDiag_injective _).comp
        Subtype.val_injective).injOn
  ┬╖ rw [Finset.sum_image]
    ┬╖ rfl
    exact ((HeckeOperator.Local.GL2.unipotentMulDiag_injective _).comp
      Subtype.val_injective).injOn

lemma U_apply_of_isUnit (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvQ : v тИИ ЁЭТо.Q) (╬▒ : v.adicCompletionIntegers F) (h╬▒ : ╬▒ тЙа 0) (h╬▒' : IsUnit ╬▒) (x) :
    (U D M ЁЭТо v hvQ ╬▒ h╬▒ x).1 =
      Matrix.GeneralLinearGroup.diagonal ![Units.mk0 ╬▒.1 (by simpa), 1] тАв тЖСx := by
  dsimp [U, LocalLevelStruct.heckeOperator]
  refine AbstractHeckeOperator.heckeOperator_eq_of_mem_normalizer _ _ ?_
  simp only [UтВБ, MulEquiv.toMonoidHom_eq_coe, hvQ, тЖУreduceIte]
  refine GL2.localBorelLevel_le_normalizer_localPTameLevel _ _ ?_
  simpa [GL2.mem_localBorelLevel_iff_v, Matrix.GeneralLinearGroup.diagonal,
    тЖР adicCompletionIntegers.isUnit_iff_valued_eq_one]

lemma adicCompletionIntegers.finite_quotient (I : Ideal (v.adicCompletionIntegers F))
    (hI : I тЙа 0) : Finite (v.adicCompletionIntegers F тз╕ I) := by
  obtain тЯи_|n, rflтЯй := (IsDiscreteValuationRing.idealOrderIsoENat _).symm.surjective I
  ┬╖ cases hI (by simp; rfl)

set_option backward.isDefEq.respectTransparency false in
lemma LocalLevelStruct.heckeOperator_eq_of_mem
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (g : GLтВВ(v.adicCompletion F)) (hg : g тИИ тДТ.US v) (x) :
    тДТ.heckeOperator D M v hv g x = x := by
  ext1
  rw [heckeOperator_eq_of_mem_normalizer (hg := Subgroup.le_normalizer hg),
    adicCompletion_smul_def]
  exact (x.2 (тДТ.incl _ тЯиg, hgтЯй)).trans (by simp [hv])

open scoped Pointwise

set_option backward.isDefEq.respectTransparency false in
lemma LocalLevelStruct.heckeOperator_map_mul_of_mem_normalizer_left
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (gтВБ gтВВ : GLтВВ(v.adicCompletion F)) (hgтВБ : gтВБ тИИ Subgroup.normalizer (тДТ.US v)) :
    тДТ.heckeOperator D M v hv gтВБ * тДТ.heckeOperator D M v hv gтВВ =
      тДТ.heckeOperator D M v hv (gтВБ * gтВВ) := by
  ext f : 2
  dsimp
  rw [LocalLevelStruct.heckeOperator_eq_of_mem_normalizer (hg := hgтВБ)]
  -- dsimp [heckeOperator]
  have H : (QuotientGroup.mk '' (тЖС(тДТ.US v) * {тЖСgтВВ}) :
      Set (GLтВВ(v.adicCompletion F) тз╕ тДТ.US v)).Finite :=
    QuotientGroup.mk_image_finite_of_compact_of_open (тДТ.isCompact_US _) (тДТ.isOpen_US _)
  rw [тДТ.heckeOperator_eq_finsetSum _ _ _ (H.image Quotient.out).toFinset,
    тДТ.heckeOperator_eq_finsetSum _ _ _
      ((H.image Quotient.out).toFinset.map (Equiv.mulLeft gтВБ))]
  ┬╖ simp [mul_smul, Finset.smul_sum]
  ┬╖ simp only [Finset.coe_map, Function.Embedding.coeFn_mk, Equiv.coe_mulLeft,
      Set.Finite.coe_toFinset]
    rw [Set.image_image]
    nth_rw 2 [тЖР Set.image_id (QuotientGroup.mk '' _)]
    refine Set.bijOn_image_image (╬▒ := GLтВВ(v.adicCompletion F) тз╕ тДТ.US v) (f := (gтВБ тАв ┬╖)) ?_ ?_ ?_
    ┬╖ refine QuotientGroup.mk_surjective.forall.mpr fun x тЖж QuotientGroup.eq.mpr ?_
      simp [тЖР QuotientGroup.eq]
    ┬╖ convert (MulAction.injective gтВБ).bijOn_image
      have H : ((тДТ.US v) * {gтВБ * gтВВ} : Set GLтВВ(v.adicCompletion F)) =
          {gтВБ} * (тЖС(тДТ.US v) * {gтВВ}) := by
        ext; simp [тЖР Subgroup.mem_normalizer_iff'.mp (inv_mem hgтВБ), mul_assoc]
      rw [H, Set.singleton_mul, тЖР Set.image_comp, тЖР Set.image_comp]
      rfl
    ┬╖ rw [Set.injOn_image_iff
        (by exact ((mul_right_injective gтВБ).comp Quotient.out_injective).injOn)]
      convert (MulAction.injective gтВБ (╬▓ := GLтВВ(v.adicCompletion F) тз╕ тДТ.US v)).injOn
      ext; simp [тЖР smul_eq_mul]
  ┬╖ simp only [Set.Finite.coe_toFinset]
    nth_rw 2 [тЖР Set.image_id (QuotientGroup.mk '' _)]
    refine Set.bijOn_image_image (f := id) (by simp) (Set.bijOn_id _) ?_
    rw [Set.injOn_image_iff Quotient.out_injective.injOn]
    simp

set_option backward.isDefEq.respectTransparency false in
lemma LocalLevelStruct.heckeOperator_map_mul_of_mem_normalizer_right
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (gтВБ gтВВ : GLтВВ(v.adicCompletion F)) (hgтВВ : gтВВ тИИ Subgroup.normalizer (тДТ.US v)) :
    тДТ.heckeOperator D M v hv gтВБ * тДТ.heckeOperator D M v hv gтВВ =
      тДТ.heckeOperator D M v hv (gтВБ * gтВВ) := by
  ext f : 2
  dsimp
  have H : (QuotientGroup.mk '' (тЖС(тДТ.US v) * {тЖСgтВБ}) :
      Set (GLтВВ(v.adicCompletion F) тз╕ тДТ.US v)).Finite :=
    QuotientGroup.mk_image_finite_of_compact_of_open (тДТ.isCompact_US _) (тДТ.isOpen_US _)
  rw [тДТ.heckeOperator_eq_finsetSum _ _ _ (H.image Quotient.out).toFinset, eq_comm,
    тДТ.heckeOperator_eq_finsetSum _ _ _ ((H.image Quotient.out).toFinset.map (Equiv.mulRight gтВВ))]
  ┬╖ rw [LocalLevelStruct.heckeOperator_eq_of_mem_normalizer (hg := hgтВВ)]
    simp [mul_smul]
  ┬╖ simp only [Finset.coe_map, Function.Embedding.coeFn_mk, Equiv.coe_mulRight,
      Set.Finite.coe_toFinset]
    rw [Set.image_image]
    nth_rw 2 [тЖР Set.image_id (QuotientGroup.mk '' _)]
    let gтВВ' : (Subgroup.normalizer (тДТ.US v : Set GLтВВ(v.adicCompletion F)))с╡Рс╡Тс╡Ц := .op тЯиgтВВ, hgтВВтЯй
    refine Set.bijOn_image_image (╬▒ := GLтВВ(v.adicCompletion F) тз╕ тДТ.US v) (f := (gтВВ' тАв ┬╖)) ?_ ?_ ?_
    ┬╖ refine QuotientGroup.mk_surjective.forall.mpr fun x тЖж QuotientGroup.eq.mpr ?_
      simp [mul_assoc, тЖР Subgroup.mem_normalizer_iff'.mp (inv_mem hgтВВ), gтВВ']
      simp [тЖР QuotientGroup.eq]
    ┬╖ convert (MulAction.injective gтВВ').bijOn_image
      rw [тЖР Set.singleton_mul_singleton, тЖР mul_assoc, Set.mul_singleton,
        тЖР Set.image_comp, тЖР Set.image_comp]
      rfl
    ┬╖ rw [Set.injOn_image_iff
        (by exact ((mul_left_injective gтВВ).comp Quotient.out_injective).injOn)]
      convert (MulAction.injective gтВВ' (╬▓ := GLтВВ(v.adicCompletion F) тз╕ тДТ.US v)).injOn
      ext a
      change gтВВ' тАв QuotientGroup.mk a.out = gтВВ' тАв a
      simp
  ┬╖ simp only [Set.Finite.coe_toFinset]
    nth_rw 2 [тЖР Set.image_id (QuotientGroup.mk '' _)]
    refine Set.bijOn_image_image (f := id) (by simp) (Set.bijOn_id _) ?_
    rw [Set.injOn_image_iff Quotient.out_injective.injOn]
    simp

open TensorProduct

set_option backward.dsimp.useDefEqAttr true in
/-- Hecke operators are preserved under the identification `ЁЭТо┬▓(U, ╧З; M тКЧ N) тЙГ M тКЧ ЁЭТо┬▓(U, ╧З; N)`. -/
lemma heckeOperatorL_tensor [тДТ.toStruct.IsSufficientlySmall D] [тДТ.toStruct.IsFinite D]
    {S N T : Type*} [CommRing S] [Module S M] [CommRing T] [Module T M] [Algebra R S] [Algebra S T]
    [AddCommGroup N] [Module S N] [Module R N]
    [IsScalarTower R S M] [IsScalarTower S T M] [SMulCommClass R T M] [IsScalarTower R S N]
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (g : GLтВВ(v.adicCompletion F)) [SMulCommClass R S M] :
    тДТ.heckeOperatorL D T (M тКЧ[S] N) v hv g = (тДТ.toStruct.formTensor D _ _ _ _).toLinearMap тИШтВЧ
      AlgebraTensorModule.lTensor T M (тДТ.heckeOperatorL D S N v hv g) тИШтВЧ
      (тДТ.toStruct.formTensor D _ _ _ _).symm.toLinearMap := by
  rw [тЖР LinearMap.comp_assoc, LinearEquiv.eq_comp_toLinearMap_symm]
  ext x y : 3
  suffices тДТ.heckeOperator D (M тКЧ[S] N) v hv g (тДТ.toStruct.formTensor D M S T N (x тКЧтВЬ[S] y)) =
      тДТ.toStruct.formTensor D M S T N (x тКЧтВЬ[S] тДТ.heckeOperator D N v hv g y) by
    simpa
  ext a
  obtain тЯиs, hsтЯй := QuotientGroup.exists_bijOn_mk_image_mul_singleton _
    (тДТ.isOpen_US v) (тДТ.isCompact_US v) g
  dsimp [LevelStruct.formTensor]
  simp only [AlgebraTensorModule.mk_apply, LevelStruct.formMapтВЧ_apply,
    LevelStruct.formMap_apply_coe, mapтВЧ_apply_toFun, LinearMap.coe_mk, AddHom.coe_mk,
    Function.comp_apply]
  rw [тДТ.heckeOperator_eq_finsetSum _ _ _ s hs, тДТ.heckeOperator_eq_finsetSum _ _ _ s hs]
  simp [tmul_sum, adicCompletion_smul_def]

set_option backward.dsimp.useDefEqAttr true in
/-- Hecke operators are preserved under the identification `ЁЭТо┬▓(U, ╧З; M) тЙГ M тКЧ ЁЭТо┬▓(U, ╧З; R)`. -/
lemma heckeOperator_eq_lTensor [тДТ.toStruct.IsSufficientlySmall D] [тДТ.toStruct.IsFinite D]
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1) (g : GLтВВ(v.adicCompletion F)) :
    тДТ.heckeOperator D M v hv g = (тДТ.toStruct.formTensorScalar D _ _).toLinearMap тИШтВЧ
      AlgebraTensorModule.lTensor R M (тДТ.heckeOperator D R v hv g) тИШтВЧ
      (тДТ.toStruct.formTensorScalar D _ _).symm.toLinearMap := by
  trans (тДТ.toStruct.formCongr D (AlgebraTensorModule.rid R R M)).toLinearMap тИШтВЧ
    тДТ.heckeOperatorL D R (M тКЧ[R] R) v hv g тИШтВЧ
    (тДТ.toStruct.formCongr D (AlgebraTensorModule.rid R R M)).symm.toLinearMap
  ┬╖ ext f a
    obtain тЯиs, hsтЯй := QuotientGroup.exists_bijOn_mk_image_mul_singleton _
      (тДТ.isOpen_US v) (тДТ.isCompact_US v) g
    simp [тДТ.heckeOperator_eq_finsetSum _ _ _ s hs, LevelStruct.formCongr, adicCompletion_smul_def]
  ┬╖ rw [heckeOperatorL_tensor]; rfl

end WeightTwoAutomorphicForm

open IsDedekindDomain.HeightOneSpectrum IsDedekindDomain.FiniteAdeleRing

open scoped FLT

open scoped TensorProduct

variable {p : тДХ}

/-- The `UтВБ` we will be considering needs the following input: -/
structure UтВБData (p : тДХ) where
  prime : p.Prime
  /-- The set of bad primes -/
  S : Finset (HeightOneSpectrum (ЁЭУЮ F))
  /-- The set of taylor wiles primes -/
  Q : Finset (HeightOneSpectrum (ЁЭУЮ F))
  /-- Characters (of order `p`) at the bad primes. -/ -- only relavent when `v тИИ S`.
  ╧ЗS (v : HeightOneSpectrum (ЁЭУЮ F)) : (IsLocalRing.ResidueField (v.adicCompletionIntegers F))╦г тЖТ* R
  ╧ЗS_pow_eq_one : тИА v тИИ S, ╧ЗS v ^ p = 1
  /-- `[F(╬╢тВЪ) : F] > 2` -/
  two_lt_finrank_cyclotomic_field : 2 < Module.finrank F (CyclotomicField p F)

variable {F R}

open scoped Classical in
/-- `UтВБ F D R SтВА SтВБ` is the open compact of `GLтВВ(ЁЭФ╕ F)` given by
`(* *; 0 *) mod v` for `v тИИ S`, `(a *; 0 d) mod v` with `p тИд ord(a/d)` for `v тИИ Q`,
and `GLтВВ(ЁЭТкс╡е)` at the rest of the places, with some order `p` character at `v тИИ S`. -/
@[simps -isSimp]
noncomputable
def UтВБ (ЁЭТо : UтВБData F R p) : WeightTwoAutomorphicForm.LocalLevelStruct F R where
  S := ЁЭТо.S тИк ЁЭТо.Q
  US v := if v тИИ ЁЭТо.Q then GL2.localPTameLevel v p else
    if v тИИ ЁЭТо.S then GL2.localBorelLevel v else GL2.localFullLevel v
  isCompact_US_of_mem v hv := by
    split_ifs with hтВБ hтВВ
    ┬╖ exact GL2.localPTameLevel.isCompact v _
    ┬╖ exact GL2.localBorelLevel.isCompact v
    ┬╖ simp_all
  isOpen_US_of_mem v hv := by
    split_ifs with hтВБ hтВВ
    ┬╖ exact GL2.localPTameLevel.isOpen v _
    ┬╖ exact GL2.localBorelLevel.isOpen v
    ┬╖ simp_all
  US_eq_of_notMem := by simp +contextual
  ╧З v := if h : v тИИ ЁЭТо.S тИз v тИЙ ЁЭТо.Q then
    ((ЁЭТо.╧ЗS v).comp (GL2.localBorelLevel.char v)).comp
      (MulEquiv.subgroupCongr ((if_neg h.2).trans (if_pos h.1))).toMonoidHom else 1
  ╧З_eq_of_notMem := by simp +contextual
  range_unitsMap_le_ker_╧З v hv := by
    by_cases h : v тИИ ЁЭТо.S тИз v тИЙ ЁЭТо.Q; swap; ┬╖ simp [h]
    simp only [h, RingHom.toMonoidHom_eq_coe, not_false_eq_true, and_self, тЖУreduceDIte,
      MulEquiv.toMonoidHom_eq_coe, MonoidHom.ker_comp_mulEquiv,
      тЖР Subgroup.comap_equiv_eq_map_symm]
    rintro тЯи_, hgтЯй тЯиg, rflтЯй
    simp only [Subgroup.mem_comap, MonoidHom.coe_coe, MonoidHom.mem_ker, MonoidHom.coe_comp,
      Function.comp_apply]
    rw [GL2.localBorelLevel.char_eq_one_iff.mpr, map_one]
    simp only [MulEquiv.subgroupCongr_apply]
    simp [Matrix.algebraMap_matrix_apply]
  isOpen_ker_╧З_of_mem v hv := by
    by_cases h : v тИИ ЁЭТо.S тИз v тИЙ ЁЭТо.Q; swap; ┬╖ simp [h]
    rw [(IsOpen.isOpenEmbedding_subtypeVal _).isOpen_iff_image_isOpen]
    ┬╖ simp only [h, SetLike.coe_sort_coe, not_false_eq_true, and_self, тЖУreduceDIte,
        MulEquiv.toMonoidHom_eq_coe, MonoidHom.ker_comp_mulEquiv, Subgroup.coe_map,
        MonoidHom.coe_coe, Set.image_image, MulEquiv.subgroupCongr_symm_apply]
      refine (IsOpen.isOpenEmbedding_subtypeVal
        (GL2.localBorelLevel.isOpen _)).isOpen_iff_image_isOpen.mp ?_
      refine Subgroup.isOpen_mono (G := GL2.localBorelLevel v)
        (MonoidHom.ker_le_ker_comp (GL2.localBorelLevel.char v) _) ?_
      rw [GL2.localBorelLevel.ker_char]
      exact (GL2.localTameLevel.isOpen v).preimage continuous_subtype_val
    ┬╖ simpa [h] using GL2.localBorelLevel.isOpen v

open Polynomial in
lemma UтВБData.eq_one_of_pow_eq_one_of_natDegree_le_two
    (ЁЭТо : UтВБData F R p)
    {K : Type*} [CommRing K] [IsDomain K] [Algebra F K] {x : K} (hx : x ^ p = 1)
    (hx'' : (minpoly F x).natDegree тЙд 2) : x = 1 := by
  by_contra hx1
  have hx' : IsIntegral F x := .of_pow ЁЭТо.prime.pos (by simp [hx, isIntegral_one])
  have H := (IsPrimitiveRoot.iff_of_prime ЁЭТо.prime).mpr тЯиhx, hx1тЯй
  have : NeZero p := тЯиЁЭТо.prime.ne_zeroтЯй
  have := (isCyclotomicExtension_singleton_iff_eq_adjoin (A := F) _ _ H).mpr rfl
  have : Module.Finite F (Algebra.adjoin F {x}) :=
    Module.Finite.iff_fg.mpr (IsIntegral.fg_adjoin_singleton hx')
  have : IsField (Algebra.adjoin F {x}) := isField_of_isIntegral_of_isField' (Field.toIsField F)
  let := this.toField
  have := ЁЭТо.two_lt_finrank_cyclotomic_field
  grw [тЖР (IsCyclotomicExtension.algEquiv {p} F (Algebra.adjoin F {x})
    (CyclotomicField p F)).toLinearEquiv.finrank_eq,
    (AlgEquiv.adjoinSingletonEquivAdjoinRootMinpoly F x).toLinearEquiv.finrank_eq,
    (AdjoinRoot.powerBasis (minpoly.ne_zero hx')).finrank, AdjoinRoot.powerBasis_dim,
    hx''] at this
  contradiction

open Polynomial in
set_option backward.isDefEq.respectTransparency false in
lemma _root_.Polynomial.cyclotomic_of_charP
    (R : Type*) [CommRing R] (p : тДХ) (hp : p.Prime) [CharP R p] :
    cyclotomic p R = (.X - 1) ^ (p - 1) := by
  suffices cyclotomic p (ZMod p) = (.X - 1) ^ (p - 1) by
    let inst : Algebra (ZMod p) R := ZMod.algebra _ _
    rw [тЖР map_cyclotomic _ (algebraMap (ZMod p) R), this]; simp
  have := Fact.mk hp
  apply mul_left_injectiveтВА (b := .X - 1) (by simpa using! X_sub_C_ne_zero 1)
  simp only [тЖР pow_succ, Nat.sub_add_cancel hp.one_le, sub_pow_char, one_pow,
    cyclotomic_prime_mul_X_sub_one]

open Polynomial in
set_option backward.isDefEq.respectTransparency false in
instance {F : Type*} [Field F] (n : тДХ) :
    IsSplittingField F (CyclotomicField n F) (cyclotomic n F) := by
  delta CyclotomicField; infer_instance

open Polynomial in
set_option backward.isDefEq.respectTransparency false in
lemma UтВБData.five_le
    (ЁЭТо : UтВБData F R p) : 5 тЙд p := by
  by_contra! H
  obtain rfl | rfl | rfl | rfl | rfl : (p = 0 тИи p = 1 тИи p = 2 тИи p = 3 тИи p = 4) := by lia
  ┬╖ simpa using ЁЭТо.prime.ne_zero
  ┬╖ simpa using ЁЭТо.prime.ne_one
  ┬╖ have := ЁЭТо.two_lt_finrank_cyclotomic_field.trans_le
      (Polynomial.IsSplittingField.finrank_le_factorial (cyclotomic 2 F))
    simp [natDegree_add_C, тЖР C.map_one, -map_one] at this
  ┬╖ have := ЁЭТо.two_lt_finrank_cyclotomic_field.trans_le
      (Polynomial.IsSplittingField.finrank_le_factorial (cyclotomic 3 F))
    simp [show (X (R := F) ^ 2 + X + 1).natDegree = 2 by compute_degree; simp] at this
  ┬╖ cases (show ┬м Nat.Prime 4 by decide) ЁЭТо.prime

open Polynomial in
set_option backward.isDefEq.respectTransparency false in
lemma UтВБData.not_charP
    (ЁЭТо : UтВБData F R p) : ┬м CharP F p := by
  intro H
  let ╧Ж : CyclotomicField p F тЖТтВР[F] F := IsSplittingField.lift (cyclotomic p F).SplittingField
    (cyclotomic p F) (by
    rw [Polynomial.cyclotomic_of_charP _ _ ЁЭТо.prime]
    simpa using (Polynomial.Splits.X_sub_C (1 : F)).pow (p - 1))
  have := ЁЭТо.two_lt_finrank_cyclotomic_field
  grw [╧Ж.toLinearMap.finrank_le_finrank_of_injective ╧Ж.injective] at this
  simp at this

lemma UтВБData.coe_ne_zero
    (ЁЭТо : UтВБData F R p) : (p : F) тЙа 0 := by
  refine fun H тЖж ЁЭТо.not_charP ?_
  exact (CharP.charP_iff_prime_eq_zero ЁЭТо.prime).mpr H

omit [WithRigidification F D] in
open Polynomial in
set_option backward.isDefEq.respectTransparency false in
lemma UтВБData.eq_one_of_pow_eq_one (ЁЭТо : UтВБData F R p)
    {x : D} (hx : x ^ p = 1) [IsQuaternionAlgebra F D] : x = 1 := by
  by_contra hx'
  let x' : Algebra.adjoin F {x} := тЯиx, Algebra.self_mem_adjoin_singleton _ _тЯй
  have : IsPrimitiveRoot x' p := IsPrimitiveRoot.iff_orderOf.mpr
    ((ЁЭТо.prime.eq_one_or_self_of_dvd _ (orderOf_dvd_of_pow_eq_one
      (by ext; simp [x', hx]))).resolve_left (by simpa [тЖР OneMemClass.coe_eq_one, x']))
  have : IsCyclotomicExtension {p} F (Algebra.adjoin F {x}) := тЯиfun {n} e _ тЖж тЯи_, e тЦ╕ thisтЯй, by
    suffices Algebra.adjoin F {b : Algebra.adjoin F {x} | b ^ p = 1} = тКд by
      simp [ЁЭТо.prime.ne_zero, this]
    apply Subalgebra.map_injective (f := Subalgebra.val _) Subtype.val_injective
    refine (Subalgebra.map_mono le_top).antisymm ?_
    simp only [Algebra.map_top, Subalgebra.range_val, AlgHom.map_adjoin, Subalgebra.coe_val,
      Algebra.adjoin_le_iff, Set.singleton_subset_iff, SetLike.mem_coe]
    exact Algebra.subset_adjoin тЯиx', by ext; simp [x', hx], rflтЯйтЯй
  have hтВБ : (minpoly F x).natDegree = 2 := by
    refine eq_of_le_of_not_lt (IsQuaternionAlgebra.natDegree_minpoly_le_two _ _) fun H тЖж ?_
    replace H : (minpoly F x).natDegree = 1 := by
      have : 0 < (minpoly F x).natDegree := minpoly.natDegree_pos (Algebra.IsIntegral.isIntegral _)
      lia
    obtain тЯиx, rflтЯй := minpoly.natDegree_eq_one_iff.mp H
    obtain rfl := ЁЭТо.eq_one_of_pow_eq_one_of_natDegree_le_two (x := x)
      ((algebraMap F D).injective (by simpa))
      ((minpoly.natDegree_eq_one_iff.mpr (by simp)).trans_le (by simp))
    simp at hx'
  have hтВВ : IsField (Algebra.adjoin F {x}) := by
    have : Irreducible (minpoly F x) := by
      by_contra H
      obtain тЯиa, b, habтЯй := ((minpoly.monic (Algebra.IsIntegral.isIntegral
        _)).not_irreducible_iff_of_natDegree_eq_two hтВБ).mp H
      have hdvd := hab.symm.dvd.trans (minpoly.dvd F x (p := .X ^ p - 1) (by simp [hx]))
      obtain rfl : a = 1 := ЁЭТо.eq_one_of_pow_eq_one_of_natDegree_le_two (x := a)
        (by simpa [sub_eq_zero] using map_dvd (aeval a) hdvd)
        ((minpoly.natDegree_eq_one_iff.mpr (by simp)).trans_le (by simp))
      obtain rfl : b = 1 := ЁЭТо.eq_one_of_pow_eq_one_of_natDegree_le_two (x := b)
        (by simpa [sub_eq_zero] using map_dvd (aeval b) hdvd)
        ((minpoly.natDegree_eq_one_iff.mpr (by simp)).trans_le (by simp))
      exact Polynomial.not_isUnit_X_sub_C 1
        (((Polynomial.X_pow_sub_C_separable_iff (n := p) (x := (1 : F))
        ЁЭТо.prime.pos one_ne_zero).mpr ЁЭТо.coe_ne_zero).squarefree _ hdvd)
    have := Fact.mk this
    refine (AlgEquiv.adjoinSingletonEquivAdjoinRootMinpoly' F x).isField (Field.toIsField _)
  let := hтВВ.toField
  refine hx' congr($(ЁЭТо.eq_one_of_pow_eq_one_of_natDegree_le_two (x := x') (by ext; simpa) ?_).1)
  rw [тЖР minpoly.algHom_eq (Subalgebra.val _) Subtype.val_injective, тЖР hтВБ]
  simp [x']

@[simp]
lemma UтВБData.╧З_apply_pow (ЁЭТо : UтВБData F R p) (v x) : ((UтВБ ЁЭТо).╧З v x) ^ p = 1 := by
  by_cases H : v тИИ ЁЭТо.S тИз v тИЙ ЁЭТо.Q
  ┬╖ simp only [UтВБ, MulEquiv.toMonoidHom_eq_coe, H, not_false_eq_true, and_self, тЖУreduceDIte]
    exact congr($(ЁЭТо.╧ЗS_pow_eq_one v H.1) _)
  ┬╖ simpa [UтВБ, H, -one_pow] using! one_pow p

@[simp] lemma UтВБData.╧З_pow (ЁЭТо : UтВБData F R p) (v) : (UтВБ ЁЭТо).╧З v ^ p = 1 := by ext; simp

@[simp] lemma UтВБData.toStruct_╧З_apply_pow (ЁЭТо : UтВБData F R p) (x) :
    (UтВБ ЁЭТо).toStruct.╧З x ^ p = 1 := by
  simp only [WeightTwoAutomorphicForm.LocalLevelStruct.toStruct]
  erw [MonoidHom.finsetProd_apply]
  simp [тЖР Finset.prod_pow]

open scoped Classical in
set_option backward.defeqAttrib.useBackward true in
instance (ЁЭТо : UтВБData F R p) [IsQuaternionAlgebra F D] [IsTotallyReal F]
    [IsQuaternionAlgebra.IsTotallyDefinite F D] :
    (UтВБ ЁЭТо).toStruct.IsSufficientlySmall D where
  isOfFinOrder_╧З := isOfFinOrder_iff_pow_eq_one.mpr тЯиp, ЁЭТо.prime.pos, by ext; simpтЯй
  coprime_╬ФIndex g := by
    refine .of_dvd_left (orderOf_dvd_of_pow_eq_one (n := p) ?_) ?_
    ┬╖ simp only [WeightTwoAutomorphicForm.LocalLevelStruct.toStruct_╧З, UтВБ_╧З]
      erw [тЖР @Finset.prod_pow]
      refine @Finset.prod_eq_one (h := fun x hx тЖж ?_)
      split_ifs with h
      ┬╖ simp_all
      ┬╖ replace hx : x тИИ ЁЭТо.S := by simp [h]
        ext a
        simpa [h, hx] using! congr($(ЁЭТо.╧ЗS_pow_eq_one _ hx) _)
      ┬╖ exact one_pow _
      ┬╖ exact one_pow _
    ┬╖ obtain тЯиg, rflтЯй := DoubleCoset.mk_surjective _ _ g
      have := (UтВБ ЁЭТо).toStruct.isFiniteRelIndex_╬Ф (D := D) g
      rw [WeightTwoAutomorphicForm.LevelStruct.╬ФIndex_mk]
      rw [ЁЭТо.prime.coprime_iff_not_dvd, Subgroup.dvd_relIndex_iff_of_prime (hp := ЁЭТо.prime)]
      rintro тЯиx, тЯиhxтВБ, _, тЯиa, rflтЯй, haтЯй, hx, u, huтЯй
      dsimp at ha hxтВБ
      have hтВБ : (a.map (Algebra.norm F)).map (algebraMap _ _).toMonoidHom =
          x.map (Algebra.norm (FiniteAdeleRing (ЁЭУЮ F) F)) := by
        rw [тЖР ha]
        dsimp
        simp only [ConjAct.smul_def, ConjAct.ofConjAct_toConjAct,
          map_mul, map_inv, mul_inv_cancel_comm]
        ext1
        dsimp
        rw [тЖР WithRigidification.det_incl_sq, Algebra.norm_eq_det, Fintype.card_fin]
      have hтВБ' : (a.map (Algebra.norm F)).map (algebraMap _ _).toMonoidHom =
          (x.map (Algebra.norm (FiniteAdeleRing (ЁЭУЮ F) F))).map
            (algebraMap _ MтВВ(FiniteAdeleRing (ЁЭУЮ F) F)).toMonoidHom := by
        rw [тЖР hтВБ]; ext1; simp [тЖР IsScalarTower.algebraMap_apply]
      have hтВВ : WithRigidification.unitsIncl F D a ^ p = u.map (algebraMap _ _).toMonoidHom := by
        apply MulAction.injective (ConjAct.toConjAct g)тБ╗┬╣
        simp only [smul_pow', ha, тЖР hu]
        rw [ConjAct.toConjAct_inv_smul']
        ext1
        simp [тЖР Algebra.commutes]
      have hтВГ : (a ^ 4 / (a.map (Algebra.norm F)).map (algebraMap F D).toMonoidHom) ^ p = 1 := by
        rw [div_eq_mul_inv, Commute.mul_pow, тЖР pow_mul, pow_mul', inv_pow, mul_inv_eq_one]
        ┬╖ apply WithRigidification.unitsIncl_injective (F := F)
          simp only [map_pow, hтВВ, WithRigidification.unitsIncl_algebraMap, hтВБ']
          simp only [тЖР map_pow, тЖР hu]
          ext1
          simp [тЖР pow_mul, тЖР IsScalarTower.algebraMap_apply]
        ┬╖ rw [Commute.inv_right_iff]
          refine Commute.pow_left (by ext; simp [Algebra.commutes]) _
      have hтВГ' : a ^ 4 = (a.map (Algebra.norm F)).map (algebraMap F D).toMonoidHom := by
        rw [тЖР div_eq_one]
        ext1
        exact ЁЭТо.eq_one_of_pow_eq_one _ (by simpa using congr(($hтВГ).1))
      have hтВГ'' : x ^ 4 = (a.map (Algebra.norm F)).map (algebraMap F _).toMonoidHom := by
        rw [тЖР ha]
        simp only [тЖР smul_pow', тЖР map_pow, hтВГ']
        ext1
        simp [ConjAct.toConjAct_inv_smul', тЖР Algebra.commutes]
      refine hx (mem_of_pow_mem_of_pow_mem_of_coprime ?_ тЯиu, huтЯй тЯи_, hтВГ''.symmтЯй)
      rw [ЁЭТо.prime.coprime_iff_not_dvd]
      exact mt (Nat.le_of_dvd (by decide)) (not_le_of_gt (.trans_le (by decide) ЁЭТо.five_le))

open scoped Adele
namespace HeckeOperator

variable (M) in
open scoped TensorProduct.RightActions Classical in
set_option backward.isDefEq.respectTransparency false in
/-- The Hecke operator T_v as an R-linear map from M-valued quaternionic weight 2
automorphic forms of level U_1(SтВА).
-/
noncomputable def T (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F)) (hvS : v тИЙ ЁЭТо.S) :
    Module.End R ((UтВБ ЁЭТо).toStruct.form D M) :=
  (UтВБ ЁЭТо).heckeOperator _ _ v (by simp [UтВБ_╧З, hvS])
    (Matrix.GeneralLinearGroup.diagonal ![v.adicCompletionUniformizerUnit F, 1])

@[simp]
lemma T_smul [SMulCommClass R S M]
    (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F)) (hvS : v тИЙ ЁЭТо.S) (r : S)
    (f : (UтВБ ЁЭТо).toStruct.form D M) : T D M ЁЭТо v hvS (r тАв f) = r тАв T D M ЁЭТо v hvS f :=
  ((UтВБ ЁЭТо).heckeOperatorL _ _ _ v (by simp [UтВБ_╧З, hvS]; rfl)
    (Matrix.GeneralLinearGroup.diagonal ![v.adicCompletionUniformizerUnit F, 1])).map_smul r f

lemma T_inv (ЁЭТо : UтВБData F R p) (v : HeightOneSpectrum (ЁЭУЮ F)) (hvS : v тИЙ ЁЭТо.S) (hvQ : v тИЙ ЁЭТо.Q) :
    (UтВБ ЁЭТо).heckeOperator _ _ v (by simp [UтВБ_╧З, hvS]; rfl)
    (Matrix.GeneralLinearGroup.diagonal ![v.adicCompletionUniformizerUnit F, 1])тБ╗┬╣ =
    T D M ЁЭТо v hvS := by
  let d : GLтВВ(v.adicCompletion F) := тЯи!![0, 1; 1, 0], !![0, 1; 1, 0],
    by simp [Matrix.one_fin_two], by simp [Matrix.one_fin_two]тЯй
  have H : (Matrix.GeneralLinearGroup.diagonal ![v.adicCompletionUniformizerUnit F, 1])тБ╗┬╣ =
      (v.adicCompletionUniformizerUnit F)тБ╗┬╣.map (algebraMap _ _).toMonoidHom * (d *
        (Matrix.GeneralLinearGroup.diagonal ![v.adicCompletionUniformizerUnit F, 1])) * d := by
    rw [eq_comm, eq_inv_iff_mul_eq_one]
    ext1
    dsimp
    simp only [Matrix.algebraMap_eq_diagonal, Matrix.diagonal_fin_two, d]
    simp [Matrix.one_fin_two]
  have hтВБ : d тИИ (UтВБ ЁЭТо).US v := by
    suffices d тИИ GL2.localFullLevel v by simpa [UтВБ, hvS, hvQ]
    simp [GL2.mem_localFullLevel_iff_v, d]
  have hтВВ : (v.adicCompletionUniformizerUnit F)тБ╗┬╣.map
      (algebraMap _ MтВВ(v.adicCompletion F)).toMonoidHom тИИ Subgroup.center _ := by
    simp [Subgroup.mem_center_iff, Units.ext_iff, Algebra.commutes]
  rw [H, тЖР (UтВБ ЁЭТо).heckeOperator_map_mul_of_mem_normalizer_right (hgтВВ := Subgroup.le_normalizer hтВБ),
    тЖР (UтВБ ЁЭТо).heckeOperator_map_mul_of_mem_normalizer_left
      (hgтВБ := Subgroup.center_le_normalizer _ hтВВ),
    тЖР (UтВБ ЁЭТо).heckeOperator_map_mul_of_mem_normalizer_left (hgтВБ := Subgroup.le_normalizer hтВБ)]
  ┬╖ ext f
    obtain тЯиs, hsтЯй := QuotientGroup.exists_bijOn_mk_image_mul_singleton _
      ((UтВБ ЁЭТо).isOpen_US v) ((UтВБ ЁЭТо).isCompact_US v)
      (Matrix.GeneralLinearGroup.diagonal ![v.adicCompletionUniformizerUnit F, 1])
    simp only [Nat.succ_eq_add_one, Nat.reduceAdd, Module.End.mul_apply, T]
    rw [(UтВБ ЁЭТо).heckeOperator_eq_of_mem_normalizer
      (hg := by exact Subgroup.center_le_normalizer _ hтВВ),
      (UтВБ ЁЭТо).heckeOperator_eq_of_mem (hg := hтВБ),
      (UтВБ ЁЭТо).heckeOperator_eq_finsetSum _ _ _ s hs,
      (UтВБ ЁЭТо).heckeOperator_eq_finsetSum _ _ _ s hs,
      (UтВБ ЁЭТо).heckeOperator_eq_of_mem (hg := hтВБ)]
    rw [WeightTwoAutomorphicForm.unitsMap_adicCompletion_smul]


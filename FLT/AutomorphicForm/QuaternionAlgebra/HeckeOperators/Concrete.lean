lemma LocalLevelStruct.exists_mul_eq (x : тДТ.toStruct.U) (v : HeightOneSpectrum (ЁЭУЮ F)) :
    тИГ a : тДТ.toStruct.U, тИГ b : тДТ.US v, GL2.toAdicCompletion v a = 1 тИз x = a * тДТ.incl v b := by
  refine тЯиx / тДТ.incl v тЯиGL2.toAdicCompletion v x, x.2 _тЯй, тЯиGL2.toAdicCompletion v x, x.2 _тЯй, ?_, ?_тЯй
  ┬╖ rw [Subgroup.coe_div, map_div, div_eq_one]
    simp [incl]
  ┬╖ simp

variable (D M) in
/-- Hecke operators on `S(U, ╧З)` given by a local element `GLтВВ(Fс╡е)`. -/
noncomputable
def LocalLevelStruct.heckeOperator (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1)
    (g : GLтВВ(v.adicCompletion F)) :
    Module.End R (тДТ.toStruct.form D M) := by
  let f :=
    AbstractHeckeOperator.heckeOperator g (тДТ.US v) (тДТ.US v)
    (R := R) (A := WeightTwoAutomorphicForm F D M)
    (QuotientGroup.mk_image_finite_of_compact_of_open (тДТ.isCompact_US _) (тДТ.isOpen_US _))
  refine ((Submodule.subtype _).comp (f.comp (Submodule.inclusion ?_))).codRestrict _ ?_
  ┬╖ intro x hx g
    refine (hx тЯи_, fun w тЖж ?_тЯй).trans ?_
    ┬╖ obtain rfl | h := eq_or_ne w v
      ┬╖ simp
      ┬╖ simp [h]
    ┬╖ trans тДТ.╧З v g тАв x
      ┬╖ congr 1; exact тДТ.╧З_incl v g
      ┬╖ simp [hv]
  ┬╖ rintro c a
    obtain тЯиa, b, ha, rflтЯй := тДТ.exists_mul_eq a v
    simp only [LinearMap.coe_comp, Submodule.coe_subtype, Function.comp_apply, mul_smul, map_mul,
      LocalLevelStruct.╧З_incl, hv, MonoidHom.one_apply, mul_one]
    refine congr(a тАв $((f _).2 b)).trans ?_
    dsimp [f]
    erw [AbstractHeckeOperator.heckeOperator_apply']
    rw [Finset.smul_sum, Finset.smul_sum]
    congr with x y
    have H : y * a * GL2.finiteAdeleIncl v x.out = y * GL2.finiteAdeleIncl v x.out * a := by
      simp only [mul_assoc]; rw [GL2.mul_comm_of_toAdicCompletion_eq_one _ _ _ ha]
    exact congr(c.1 $H).trans congr($(c.2 a) (y * GL2.finiteAdeleIncl v x.out))

set_option backward.isDefEq.respectTransparency false in
lemma LocalLevelStruct.heckeOperator_mul_comm_of_ne
    (v w : HeightOneSpectrum (ЁЭУЮ F)) (hv : тДТ.╧З v = 1) (hw : тДТ.╧З w = 1)
    (gv : GLтВВ(v.adicCompletion F)) (gw : GLтВВ(w.adicCompletion F)) (hvw : v тЙа w) :
    тДТ.heckeOperator D M v hv gv * тДТ.heckeOperator D M w hw gw =
      тДТ.heckeOperator D M w hw gw * тДТ.heckeOperator D M v hv gv := by
  ext f : 2
  repeat dsimp [heckeOperator]; rw [AbstractHeckeOperator.heckeOperator_apply']
  simp only [Finset.smul_sum, adicCompletion_smul_def, тЖР mul_smul]
  rw [Finset.sum_comm]
  congr! 3 with a ha b hb
  rw [GL2.mul_comm_of_toAdicCompletion_eq_one _ _ _ (by simp [hvw.symm])]


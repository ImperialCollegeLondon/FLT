open HeckeOperator

variable (ЁЭТо : UтВБData F R p)

/--
Given `ЁЭТо : UтВБData F R p`, `HeckeAlgebra D ЁЭТо` is the Hecke algebra associated to the weight 2
`R`-valued automorphic forms associated to the discriminant 1 totally definite
quaternion algebra `D` over the totally real field `F`, of level `UтВБ(S, Q)` where `S` is
a finite set of nonzero primes `v` of `ЁЭУЮ F`. To make sense of this definition we choose
a rigidification, that is, a fixed `ЁЭФ╕_F^тИЮ`-linear
isomorphism `D тКЧ[F] ЁЭФ╕_F^тИЮ = MтВВ(ЁЭФ╕_F^тИЮ)`, enabling us to define level structures and
Hecke operators `Tс╡е` and `Uс╡е` using 2x2 matrices.

Details:
`ЁЭТо : UтВБData F R p` consist of a set of bad primes `S` of `F` with order `p` characters `k(v) тЖТ* R`,
and a set of taylor wiles primes `Q`.

`UтВБ(S, Q)` is the subgroup of `(D тКЧ[F] ЁЭФ╕_F^тИЮ)╦г` associated, via `r`, to the
matrices which are in `GLтВВ(ЁЭУЮс╡е)` for all `v тИЙ S тИк Q` and which are of the form
`(* *; 0 *)` mod `v` for all `v тИИ S`, and `(a *; 0 d)` mod `v` with `p тИд ord(a/d)` for `v тИИ Q`.

The Hecke algebra is defined to be the
sub-`R`-algebra of the weight 2 forms of level `UтВБ(S, Q)` generated by the following
two kinds of Hecke operators: first there are the operators
`Tс╡е` associated to the matrices `(╧Цс╡е 0; 0 1)` for `v тИЙ S тИк Q` (here `╧Цс╡е тИИ ЁЭФ╕_F^тИЮ` is a local
uniformiser supported at `v`). Second, there are the Hecke operators `Uс╡е,тВР`
for `v тИИ Q` and `0 тЙа ╬▒с╡е тИИ ЁЭУЮс╡е`, associated the matries `(╬▒с╡е 0; 0 1)`.
These slightly nonstandard Hecke operators satisfy `Uс╡е,тВЫ * Uс╡е,тВЬ = Uс╡е,тВЫтВЬ`
and in particular this Hecke algebra is commutative (Hecke operators supported
at distinct primes commute because the decomposition of the double cosets
into single cosets can be done purely locally).
-/
def HeckeAlgebra (ЁЭТо : UтВБData F R p) : Type _ :=
  (Algebra.adjoin R ({ T D R ЁЭТо v hv | (v) (hv : v тИЙ ЁЭТо.S) (_ : v тИЙ ЁЭТо.Q) } тИк
      { U D R ЁЭТо v hv ╬▒ h╬▒ | (v) (hv : v тИИ ЁЭТо.Q) (╬▒) (h╬▒) }) :
    Subalgebra R (Module.End R ((UтВБ ЁЭТо).toStruct.form D R)))

namespace HeckeAlgebra

noncomputable instance instRing :
    Ring (HeckeAlgebra D ЁЭТо) := inferInstanceAs <|
  Ring (Algebra.adjoin R _ : Subalgebra R _)

noncomputable instance instAlgebra :
    Algebra R (HeckeAlgebra D ЁЭТо) := inferInstanceAs <|
  Algebra R (Algebra.adjoin R _ : Subalgebra R _)

noncomputable instance :
    IsMulCommutative (HeckeAlgebra D ЁЭТо) := by
  refine Algebra.isMulCommutative_adjoin R ?_
  rintro x (тЯиv, hvS, hvQ, rflтЯй|тЯиv, hv, ╬▒, h╬▒, rflтЯй) y (тЯиw, hwS, hwQ, rflтЯй|тЯиw, hw, ╬▓, h╬▓, rflтЯй)
  ┬╖ obtain rfl | hvw := eq_or_ne v w
    ┬╖ rfl
    ┬╖ exact (UтВБ ЁЭТо).heckeOperator_mul_comm_of_ne _ _ _ _ _ _ hvw
  ┬╖ obtain rfl | hvw := eq_or_ne v w
    ┬╖ contradiction
    ┬╖ exact (UтВБ ЁЭТо).heckeOperator_mul_comm_of_ne _ _ _ _ _ _ hvw
  ┬╖ obtain rfl | hvw := eq_or_ne v w
    ┬╖ contradiction
    ┬╖ exact (UтВБ ЁЭТо).heckeOperator_mul_comm_of_ne _ _ _ _ _ _ hvw
  ┬╖ obtain rfl | hvw := eq_or_ne v w
    ┬╖ rw [U_mul_U, U_mul_U]; rw! [mul_comm]; rfl
    ┬╖ exact (UтВБ ЁЭТо).heckeOperator_mul_comm_of_ne _ _ _ _ _ _ hvw

noncomputable instance instCommRing :
    CommRing (HeckeAlgebra D ЁЭТо) :=
  open scoped IsMulCommutative in inferInstance

/-- The Hecke operator Tс╡е as an element of the Hecke algebra. -/
noncomputable def T (ЁЭТо : UтВБData F R p)
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hvS : v тИЙ ЁЭТо.S) (hvQ : v тИЙ ЁЭТо.Q) : HeckeAlgebra D ЁЭТо :=
  тЯиHeckeOperator.T D R ЁЭТо v hvS, Algebra.subset_adjoin (.inl тЯи_, hvS, hvQ, rflтЯй)тЯй

open scoped Classical in
set_option backward.isDefEq.respectTransparency false in
/-- The Hecke operator Uс╡е,тВР as an element of the Hecke algebra. -/
noncomputable def U (ЁЭТо : UтВБData F R p)
    (v : HeightOneSpectrum (ЁЭУЮ F)) (hv : v тИИ ЁЭТо.Q) :
    v.adicCompletionIntegers F тЖТ*тВА HeckeAlgebra D ЁЭТо where
  toFun ╬▒ := if h╬▒ : ╬▒ = 0 then 0 else
    тЯиHeckeOperator.U D R ЁЭТо v hv ╬▒ h╬▒, Algebra.subset_adjoin (.inr тЯиv, hv, ╬▒, h╬▒, rflтЯй)тЯй
  map_one' := by
    simp only [one_ne_zero, тЖУreduceDIte, ne_eq]
    refine Subtype.ext ?_
    ext x : 2
    refine (U_apply_of_isUnit D ЁЭТо v hv 1 (by simp) (by simp) _).trans ?_
    simp
  map_mul' x y := by
    by_cases hx : x = 0
    ┬╖ simp [hx]
    by_cases hy : y = 0
    ┬╖ simp [hy]
    simp only [mul_eq_zero, hx, hy, or_self, тЖУreduceDIte, ne_eq]
    exact Subtype.ext (U_mul_U D ЁЭТо v hv x y hx hy).symm
  map_zero' := dif_pos rfl

set_option backward.isDefEq.respectTransparency false in
lemma adjoin_T_U_eq_top :
    Algebra.adjoin R ({ T D ЁЭТо v hv hvQ | (v) (hv : v тИЙ ЁЭТо.S) (hvQ : v тИЙ ЁЭТо.Q) } тИк
      { U D ЁЭТо v hv ╬▒ | (v) (hv : v тИИ ЁЭТо.Q) (╬▒) (_ : ╬▒ тЙа 0) }) = тКд := by
  refine Subalgebra.map_injective (f := Subalgebra.val
    (Algebra.adjoin R (A := (Module.End R ((UтВБ ЁЭТо).toStruct.form D R))) _))
    Subtype.val_injective ?_
  refine (Subalgebra.map_mono le_top).antisymm ?_
  rw [Algebra.map_top, AlgHom.map_adjoin, Subalgebra.range_val, Set.image_union]
  refine Algebra.adjoin_mono (Set.union_subset_union ?_ ?_)
  ┬╖ exact fun x тЯиv, hv, hvQ, eтЯй тЖж тЯиT D ЁЭТо v hv hvQ, тЯи_, _, _, rflтЯй, eтЯй
  ┬╖ exact fun x тЯиv, hv, ╬▒, h╬▒, eтЯй тЖж тЯиU D ЁЭТо v hv ╬▒, тЯи_, _, _, h╬▒, rflтЯй,
      .trans (by simp [U, h╬▒]) eтЯй

variable [IsQuaternionAlgebra F D] [IsTotallyReal F]
    [IsQuaternionAlgebra.IsTotallyDefinite F D]

noncomputable instance :
    Module (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D M) :=
  letI : Module (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D R) :=
    inferInstanceAs <| Module (Algebra.adjoin _ _) _
  letI : IsScalarTower R (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D R) := inferInstanceAs <|
    IsScalarTower R (Algebra.adjoin _ _) _
  (TensorProduct.comm _ _ _ тЙктЙлтВЧ (UтВБ ЁЭТо).toStruct.formTensorScalar D M R).symm.toAddEquiv.module _

private lemma smul_formTensorScalar_aux (ЁЭТо : UтВБData F R p)
    (T : HeckeAlgebra D ЁЭТо) (m : M) (f : (UтВБ ЁЭТо).toStruct.form D R) :
    T тАв (UтВБ ЁЭТо).toStruct.formTensorScalar D M R (m тКЧтВЬ f) =
      (UтВБ ЁЭТо).toStruct.formTensorScalar D M R (m тКЧтВЬ T.1 f) := by
  change (UтВБ ЁЭТо).toStruct.formTensorScalar D M R _ = _
  dsimp
  simp only [LinearEquiv.symm_apply_apply, TensorProduct.comm_tmul]
  rfl

/-- Note: This breaks the abstraction boundary that `HeckeAlgebra` is defined as a
subtype under the hood. This should only be used in the backward direction to remove the abuse. -/
lemma smul_eq_apply (ЁЭТо : UтВБData F R p)
    (T : HeckeAlgebra D ЁЭТо) (f : (UтВБ ЁЭТо).toStruct.form D R) :
    T тАв f = T.1 f := by
  convert smul_formTensorScalar_aux D ЁЭТо T (1 : R) f
  ┬╖ ext
    dsimp [WeightTwoAutomorphicForm.LevelStruct.formTensorScalar,
      WeightTwoAutomorphicForm.LevelStruct.formTensor]
    simp
  ┬╖ ext
    dsimp [WeightTwoAutomorphicForm.LevelStruct.formTensorScalar,
      WeightTwoAutomorphicForm.LevelStruct.formTensor]
    simp

lemma smul_formTensorScalar (ЁЭТо : UтВБData F R p)
    (T : HeckeAlgebra D ЁЭТо) (m : M) (f : (UтВБ ЁЭТо).toStruct.form D R) :
    T тАв (UтВБ ЁЭТо).toStruct.formTensorScalar D M R (m тКЧтВЬ f) =
      (UтВБ ЁЭТо).toStruct.formTensorScalar D M R (m тКЧтВЬ (T тАв f)) := by
  rw [smul_formTensorScalar_aux, тЖР smul_eq_apply]

lemma T_smul_def (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvS : v тИЙ ЁЭТо.S) (hvQ : v тИЙ ЁЭТо.Q) (f : (UтВБ ЁЭТо).toStruct.form D M) :
    T D ЁЭТо v hvS hvQ тАв f = HeckeOperator.T D M ЁЭТо v hvS f := by
  obtain тЯиf, rflтЯй := ((UтВБ ЁЭТо).toStruct.formTensorScalar D M R).surjective f
  induction f with
  | zero => simp
  | add x y _ _ => simp only [*, map_add, smul_add]
  | tmul x y =>
    dsimp [HeckeOperator.T]
    rw [TotallyDefiniteQuaternionAlgebra.WeightTwoAutomorphicForm.heckeOperator_eq_lTensor]
    simp [smul_formTensorScalar, smul_eq_apply]
    rfl

lemma U_smul_def (v : HeightOneSpectrum (ЁЭУЮ F))
    (hvQ : v тИИ ЁЭТо.Q) (a : v.adicCompletionIntegers F) (ha : a тЙа 0) (f : (UтВБ ЁЭТо).toStruct.form D M) :
    U D ЁЭТо v hvQ a тАв f = HeckeOperator.U D M ЁЭТо v hvQ a ha f := by
  obtain тЯиf, rflтЯй := ((UтВБ ЁЭТо).toStruct.formTensorScalar D M R).surjective f
  induction f with
  | zero => simp
  | add x y _ _ => simp only [*, map_add, smul_add]
  | tmul x y =>
    dsimp [HeckeOperator.U]
    rw [TotallyDefiniteQuaternionAlgebra.WeightTwoAutomorphicForm.heckeOperator_eq_lTensor]
    simp [smul_formTensorScalar, smul_eq_apply, U, ha]
    rfl

lemma formMap_smul {N : Type*} [AddCommGroup N] [Module R N] (ЁЭТо : UтВБData F R p)
    (╧Ж : M тЖТтВЧ[R] N) (T : HeckeAlgebra D ЁЭТо) (f : (UтВБ ЁЭТо).toStruct.form D M) :
    (UтВБ ЁЭТо).toStruct.formMap D ╧Ж (T тАв f) = T тАв (UтВБ ЁЭТо).toStruct.formMap D ╧Ж f := by
  obtain тЯиf, rflтЯй := ((UтВБ ЁЭТо).toStruct.formTensorScalar D M R).surjective f
  induction f with
  | zero => simp
  | add x y _ _ => simp only [*, map_add, smul_add]
  | tmul x y =>
    rw [smul_formTensorScalar]
    convert (smul_formTensorScalar D ЁЭТо T (╧Ж x) y).symm using 1
    ┬╖ ext g; simp
    ┬╖ congr 1; ext g; simp

noncomputable instance :
    IsScalarTower R (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D M) :=
  .of_algebraMap_smul fun r f тЖж by
    letI : Module (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D R) :=
      inferInstanceAs <| Module (Algebra.adjoin _ _) _
    letI : IsScalarTower R (HeckeAlgebra D ЁЭТо) ((UтВБ ЁЭТо).toStruct.form D R) := inferInstanceAs <|
      IsScalarTower R (Algebra.adjoin _ _) _
    change (UтВБ ЁЭТо).toStruct.formTensorScalar D M R _ = _
    conv_lhs => enter [2, 2]; tactic => exact algebraMap_smul (HeckeAlgebra D ЁЭТо) r _
    simp

noncomputable instance [SMulCommClass R S M] :
    SMulCommClass (HeckeAlgebra D ЁЭТо) S ((UтВБ ЁЭТо).toStruct.form D M) where
  smul_comm T r := by
    induction (adjoin_T_U_eq_top ..).ge (Set.mem_univ T) using Algebra.adjoin_induction with
    | algebraMap s => simp [smul_comm]
    | add x y hx hy _ _ => simp [*, add_smul]
    | mul x y hx hy _ _ => intro f; simp [mul_smul, *]
    | mem x hx =>
      intro f
      obtain тЯиv, hvS, hvQ, rflтЯй | тЯиv, hvQ, ╬▒, h╬▒, rflтЯй := hx
      ┬╖ simp [T_smul_def]
      ┬╖ simp [U_smul_def, h╬▒]


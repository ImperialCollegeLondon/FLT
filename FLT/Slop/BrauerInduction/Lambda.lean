/-!

# Bernstein's coefficient ring `őõ`

This file introduces the coefficient ring `őõ` used in Bernstein's proof of
Brauer induction. For a group `G` and coefficient ring `k`, `őõ` is the subring
of `k` generated by the `|G|`-th roots of unity.

The file also defines `ClassFun.HasLambdaCoords`, expressing that a class
function has coordinates in `őõ` with respect to an irreducible-character basis.

The main results are:

* `ClassFun.Lambda.moduleFinite`: `őõ` is a finitely generated `‚Ą§`-module.
* `ClassFun.Lambda.moduleFree`: `őõ` is a free `‚Ą§`-module in characteristic zero.
* `ClassFun.Lambda.one_is_primitive`: `1 : őõ` is primitive as an element of the
  `‚Ą§`-module `őõ`.
* `ClassFun.Lambda.char_coeffs`: the coordinates of a representation character
  in an irreducible-character basis lie in `őõ`.
* `ClassFun.HasLambdaCoords.character`: representation characters have
  `őõ`-coordinates in an irreducible-character basis.

Pure roots-of-unity facts used here are kept in
`BrauerInduction.Background.RingTheory.RootsOfUnity`.
Pointwise integer-valued class functions are developed separately in
`BrauerInduction.Background.ClassFun.Integral`.
-/

@[expose] public section

namespace Slop
open Slop

universe u v

namespace ClassFun

section Lambda

variable {G : Type v} [Group G]

/--
Bernstein's coefficient ring `őõ`: the subring of `k` generated by the
`|G|`-th roots of unity.
-/
def Lambda (k : Type u) (G : Type v) [Group G] [CommRing k] : Subring k :=
  Subring.closure (Set.range
    (fun (x : rootsOfUnity (Nat.card G) k) => (x.val : k)))

namespace Lambda

/--
Scalar multiplication by an element of `őõ` acts pointwise through its coercion
to `k`.
-/
@[simp]
lemma smul_apply {k : Type u} [CommRing k]
    (a : ClassFun.Lambda k G) (f : ClassFun k G) (x : G) :
    (a ‚ÄĘ f) x = (a : k) * f x := by
  rfl

-- Keep this instance local: globally registering this module structure tends to
-- create fragile diamonds with the existing `k`-module structure.
local instance {k : Type u} [CommRing k] (H : Subgroup G) :
    Module (Lambda k G) (ClassFun k H) :=
  Module.compHom (ClassFun k H) (Lambda k G).subtype

/--
The cyclotomic coefficient ring `őõ` is a finitely generated `‚Ą§`-module.
-/
noncomputable instance moduleFinite
    {k : Type u} [Field k]
    [NeZero (Nat.card G)] :
    Module.Finite ‚Ą§ (Lambda k G) := by
  let s : Set k :=
    Set.range (fun (ő∂ : rootsOfUnity (Nat.card G) k) => (ő∂.val : k))
  letI : Fintype (rootsOfUnity (Nat.card G) k) :=
    Fintype.ofFinite _
  have h_fin : s.Finite := Set.finite_range _
  have h_int : ‚ąÄ x ‚ąą s, IsIntegral ‚Ą§ x := by
    rintro x ‚ü®ő∂, rfl‚ü©
    exact rootsOfUnity.isIntegral_of_ne_zero
      k (Nat.card G) (NeZero.ne (Nat.card G)) ő∂
  let A : Subalgebra ‚Ą§ k := Algebra.adjoin ‚Ą§ s
  haveI : Module.Finite ‚Ą§ A :=
    Algebra.finite_adjoin_of_finite_of_isIntegral h_fin h_int
  haveI : IsNoetherian ‚Ą§ A := inferInstance
  have h_le : ‚ąÄ x ‚ąą Lambda k G, x ‚ąą A := by
    intro x hx
    unfold Lambda at hx
    have h_subset : s ‚äÜ A.toSubring := Algebra.subset_adjoin
    exact Subring.closure_le.mpr h_subset hx
  let f : Lambda k G ‚Üí‚āó[‚Ą§] A :=
    { toFun := fun x => ‚ü®x.1, h_le x.1 x.2‚ü©
      map_add' := fun x y => by ext; rfl
      map_smul' := fun c x => by ext; rfl }
  have h_inj : Function.Injective f := by
    intro x y h
    ext
    exact congrArg (fun a : A => a.val) h
  exact Module.Finite.of_injective f h_inj

/--
The cyclotomic coefficient ring `őõ` is a free `‚Ą§`-module.

This follows from finite generation and torsion-freeness over the PID `‚Ą§`.
-/
noncomputable instance moduleFree
    (k : Type u) [Field k] [CharZero k]
    (G : Type v) [Group G]
    [Module.Finite ‚Ą§ (Lambda k G)] : Module.Free ‚Ą§ (Lambda k G) := by
  haveI : NoZeroSMulDivisors ‚Ą§ (Lambda k G) := by
    constructor
    intro a x h_smul
    have h_field :
      (a : k) * (x : k) = 0 := by
      calc (a : k) * (x : k) = ‚ÜĎ(a ‚ÄĘ x) := by
            simp only [zsmul_eq_mul, Subring.coe_mul, SubringClass.coe_intCast]
        _ = (0 : Lambda k G) := by rw [h_smul]
        _ = 0 := rfl
    cases mul_eq_zero.mp h_field with
    | inl ha_zero =>
        left
        exact_mod_cast ha_zero
    | inr hx_zero =>
        right
        ext
        exact hx_zero
  obtain ‚ü®_, b‚ü© := Module.basisOfFiniteTypeTorsionFree' (R := ‚Ą§) (M := Lambda k G)
  exact Module.Free.of_basis b

/--
The element `1 : őõ` is primitive as a `‚Ą§`-module element: if `m ‚ÄĘ x = 1`,
then `m` is a unit of `‚Ą§`.
-/
lemma one_is_primitive
    {k : Type u} [Field k] [CharZero k] [Finite G]
    (m : ‚Ą§) (x : Lambda k G) (h : m ‚ÄĘ x = 1) :
    IsUnit m := by
  haveI: NeZero (Nat.card G) := ‚ü®One.natCard_ne_zero_of_finite G‚ü©
  have h_field : (m : k) * (x : k) = 1 := by
    have h_coe := congrArg (fun y : Lambda k G => (y : k)) h
    simp only [Subring.coe_one, zsmul_eq_mul] at h_coe
    exact h_coe
  have hx_int : IsIntegral ‚Ą§ (x : k) := by
    have H_le : Lambda k G ‚Č§ (integralClosure ‚Ą§ k).toSubring := by
      rw [Lambda, Subring.closure_le]
      rintro _ ‚ü®u, rfl‚ü©
      exact rootsOfUnity.isIntegral k G u
    exact H_le x.property
  have hm_neq_zero : (m : k) ‚Č† 0 := by
    intro hz
    rw [hz, zero_mul] at h_field
    exact zero_ne_one h_field
  have hx_eq : (x : k) = (m : k)‚ĀĽ¬Ļ := by
    apply eq_inv_of_mul_eq_one_left
    simpa [mul_comm] using h_field
  rw [hx_eq] at hx_int
  have h_rat : (m : k)‚ĀĽ¬Ļ = algebraMap ‚Ąö k ((m : ‚Ąö)‚ĀĽ¬Ļ) := by
    simp only [map_inv‚āÄ, map_intCast]
  rw [h_rat] at hx_int
  have h_int_Q : IsIntegral ‚Ą§ ((m : ‚Ąö)‚ĀĽ¬Ļ) :=
    (isIntegral_algebraMap_iff (algebraMap ‚Ąö k).injective).mp hx_int
  have h_in_Z : ‚ąÉ z : ‚Ą§, algebraMap ‚Ą§ ‚Ąö z = (m : ‚Ąö)‚ĀĽ¬Ļ :=
    IsIntegrallyClosed.isIntegral_iff.mp h_int_Q
  obtain ‚ü®z, hz‚ü© := h_in_Z
  have hm_Q_neq_zero : (m : ‚Ąö) ‚Č† 0 := by
    intro hz_Q
    have : (m : k) = 0 := by exact_mod_cast hz_Q
    exact hm_neq_zero this
  have h_zm_Q : (z : ‚Ąö) * (m : ‚Ąö) = 1 := by
    calc
      (z : ‚Ąö) * (m : ‚Ąö)
          = (m : ‚Ąö)‚ĀĽ¬Ļ * (m : ‚Ąö) := by
              simp only [mul_eq_mul_right_iff, hm_Q_neq_zero]
              rw [‚Üź hz]
              simp only [algebraMap_int_eq, eq_intCast, or_false]
      _ = 1 := inv_mul_cancel‚āÄ hm_Q_neq_zero
  have h_zm_Z : z * m = 1 := by
    exact_mod_cast h_zm_Q
  rw [mul_comm] at h_zm_Z
  exact IsUnit.of_mul_eq_one z h_zm_Z

lemma rootsOfUnity_orderOf_mem_Lambda
    {k : Type u} [CommRing k] [Finite G]
    (a : G) (ő∂ : rootsOfUnity (orderOf a) k) :
    (((ő∂ : kň£) : k)) ‚ąą Lambda k G := by
  have hdiv : orderOf a ‚ą£ Nat.card G := by
    simpa using orderOf_dvd_natCard a
  rcases hdiv with ‚ü®m, hm‚ü©
  let ő∑ : rootsOfUnity (Nat.card G) k :=
    ‚ü®(ő∂ : kň£), by
      calc
        ((ő∂ : kň£) ^ Nat.card G)
            = ((ő∂ : kň£) ^ orderOf a) ^ m := by
                rw [hm, pow_mul]
        _ = 1 := by
                rw [ő∂.property, one_pow]‚ü©
  change (((ő∂ : kň£) : k)) ‚ąą
    Subring.closure (Set.range (fun x : rootsOfUnity (Nat.card G) k => ((x.val : kň£) : k)))
  exact Subring.subset_closure ‚ü®ő∑, rfl‚ü©

/--
The value of a linear character of a subgroup of `G` lies in Bernstein's
coefficient ring `őõ` formed using the ambient group `G`.
-/
lemma linearChar_apply_mem_Lambda
    {k : Type u} [CommRing k] [Finite G]
    (Ōá : G ‚Üí* kň£) (g : G) :
    ((Ōá g : kň£) : k) ‚ąą Lambda k G := by
  letI : Fintype G := Fintype.ofFinite G
  have hg : g ^ Fintype.card G = 1 := by exact pow_card_eq_one
  have hŌá_card : Ōá g ^ Fintype.card G = 1 := by
    calc
      Ōá g ^ Fintype.card G = Ōá (g ^ Fintype.card G) := by
        exact (map_pow Ōá g (Fintype.card G)).symm
      _ = Ōá 1 := by
        exact congrArg Ōá hg
      _ = 1 := by
        exact map_one Ōá
  have hŌá : Ōá g ^ Nat.card G = 1 := by
    simpa [Nat.card_eq_fintype_card] using hŌá_card
  let ő∑ : rootsOfUnity (Nat.card G) k :=
    ‚ü®Ōá g, hŌá‚ü©
  change ((Ōá g : kň£) : k) ‚ąą
    Subring.closure
      (Set.range
        (fun x : rootsOfUnity (Nat.card G) k => ((x.val : kň£) : k)))
  exact Subring.subset_closure ‚ü®ő∑, rfl‚ü©

lemma linearChar_subgroup_apply_mem_Lambda
    {k : Type u} [CommRing k] [Finite G]
    {H : Subgroup G}
    (Ōá : H ‚Üí* kň£) (h : H) :
    ((Ōá h : kň£) : k) ‚ąą Lambda k G := by
  letI : Fintype G := Fintype.ofFinite G
  have hG : (h : G) ^ Fintype.card G = 1 := by
    exact pow_card_eq_one
  have hH : h ^ Fintype.card G = 1 := by
    apply Subtype.ext
    simp
  have hŌá_card : Ōá h ^ Fintype.card G = 1 := by
    calc
      Ōá h ^ Fintype.card G = Ōá (h ^ Fintype.card G) := by
        exact (map_pow Ōá h (Fintype.card G)).symm
      _ = Ōá 1 := by
        exact congrArg Ōá hH
      _ = 1 := by
        exact map_one Ōá
  have hŌá : Ōá h ^ Nat.card G = 1 := by
    simpa [Nat.card_eq_fintype_card] using hŌá_card
  let ő∑ : rootsOfUnity (Nat.card G) k :=
    ‚ü®Ōá h, hŌá‚ü©
  change ((Ōá h : kň£) : k) ‚ąą
    Subring.closure
      (Set.range
        (fun x : rootsOfUnity (Nat.card G) k => ((x.val : kň£) : k)))
  exact Subring.subset_closure ‚ü®ő∑, rfl‚ü©

end Lambda
end Lambda

section coeffs

variable {k : Type u} [Field k]
variable {G : Type v} [Group G]

/--
The coordinates of a character in an irreducible-character basis lie in `őõ`.
-/
lemma Lambda.char_coeffs
    {k : Type u} [Field k] [CharZero k]
    {G : Type u} [Group G] [Finite G]
    (B : ClassFun.IrrepCharBasis k G)
    (U : FDRep k G) (i : B.őĻ) :
    B.b.repr (ClassFun.character U) i ‚ąą ClassFun.Lambda k G := by
  obtain ‚ü®m, hm‚ü© := ClassFun.char_coeffs_int B U i
  rw [hm]
  have h_smul : (m : k) = m ‚ÄĘ (1 : k) := by
    exact (zsmul_one m).symm
  rw [h_smul]
  exact Subring.zsmul_mem (ClassFun.Lambda k G) (Subring.one_mem _) m

/--
A class function has `őõ`-coordinates with respect to an irreducible-character
basis if every coordinate in that basis lies in `őõ`.
-/
def HasLambdaCoords
    (B : ClassFun.IrrepCharBasis k G) (f : ClassFun k G) : Prop :=
  ‚ąÄ i : B.őĻ, B.b.repr f i ‚ąą ClassFun.Lambda k G

namespace HasLambdaCoords

/-- The zero class function has `őõ`-coordinates. -/
lemma zero
    (B : ClassFun.IrrepCharBasis k G) :
    HasLambdaCoords B 0 := by
  intro i
  simp

/-- Class functions with `őõ`-coordinates are closed under addition. -/
lemma add
    (B : ClassFun.IrrepCharBasis k G)
    {f g : ClassFun k G}
    (hf : HasLambdaCoords B f)
    (hg : HasLambdaCoords B g) :
    HasLambdaCoords B (f + g) := by
  intro i
  simp only [HasLambdaCoords, map_add, Finsupp.coe_add, Pi.add_apply] at *
  exact add_mem (hf i) (hg i)

/-- Characters have `őõ`-coordinates in an irreducible-character basis. -/
lemma character [CharZero k]
    {G : Type u} [Group G] [Finite G]
    (B : ClassFun.IrrepCharBasis k G)
    (U : FDRep k G) :
    HasLambdaCoords B (ClassFun.character U) := by
  intro i
  exact Lambda.char_coeffs B U i

/--
Class functions with `őõ`-coordinates are closed under integer scalar
multiplication.
-/
lemma zsmul
    (B : ClassFun.IrrepCharBasis k G)
    (z : ‚Ą§) {f : ClassFun k G}
    (hf : HasLambdaCoords B f) :
    HasLambdaCoords B (z ‚ÄĘ f) := by
  intro i
  have h_zsmul_f :
      z ‚ÄĘ f = (z : k) ‚ÄĘ f :=
    Eq.symm (Int.cast_smul_eq_zsmul k z f)
  rw [h_zsmul_f, LinearEquiv.map_smul]
  change (z : k) * (B.b.repr f i) ‚ąą ClassFun.Lambda k G
  have h_mul_to_zsmul :
      (z : k) * (B.b.repr f i) =
        z ‚ÄĘ (B.b.repr f i) := by
    exact Eq.symm (zsmul_eq_mul (B.b.repr f i) z)
  rw [h_mul_to_zsmul]
  exact Subring.zsmul_mem (ClassFun.Lambda k G) (hf i) z

/--
Class functions with `őõ`-coordinates are closed under scalar multiplication
by elements of `őõ`.
-/
lemma smul
    (B : ClassFun.IrrepCharBasis k G)
    {a : k} (ha : a ‚ąą ClassFun.Lambda k G)
    {f : ClassFun k G}
    (hf : HasLambdaCoords B f) :
    HasLambdaCoords B (a ‚ÄĘ f) := by
  intro i
  rw [LinearEquiv.map_smul]
  change a * (B.b.repr f i) ‚ąą ClassFun.Lambda k G
  exact Subring.mul_mem _ ha (hf i)

end HasLambdaCoords
end coeffs
end ClassFun


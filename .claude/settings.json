{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": ["Bash(git push:*)"]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "failIfUnavailable": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "reservoir.lean-lang.org",
        "release.lean-lang.org",
        "elan.lean-lang.org"
      ]
    },
    "filesystem": {
      "allowWrite": ["~/.elan", "~/.cache/mathlib"]
    }
  }
}
